<view class="page">

  <view class="page-container" style="--status-bar-height: {{statusBarHeight}}px;">
    <scroll-view class="scrollarea" scroll-y>
      <view class="content">
        <!-- 头部个人信息卡片 -->
        <view class="profile-header" style="--status-bar-height: {{statusBarHeight}}px;">
          <!-- 未登录状态 -->
          <view wx:if="{{!isLoggedIn}}" class="profile-card" bindtap="onLoginTap" hover-class="is-pressed" hover-stay-time="120">
            <view class="profile-avatar-wrapper">
              <image 
                class="profile-avatar" 
                src="/images/pic/avatar.png"
                mode="aspectFill" 
              />
            </view>
            <view class="profile-info">
              <view class="profile-login-row">
                <text class="profile-name">登录/注册</text>
                <view class="login-btn">
                  <text class="login-btn-text">立即登录</text>
                  <text class="login-btn-arrow">›</text>
                </view>
              </view>
              <text class="profile-subtitle">登录后查看更多信息</text>
            </view>
          </view>

          <!-- 已登录状态 -->
          <view wx:else class="profile-card">
            <view class="profile-avatar-wrapper">
              <image 
                class="profile-avatar" 
                src="/images/pic/avatar.png"
                mode="aspectFill" 
              />
              <view wx:if="{{currentStudent}}" class="profile-badge">{{currentStudent.level || '未评测'}}</view>
            </view>
            <view class="profile-info">
              <view class="profile-logged">
                <view class="profile-name-row">
                  <text class="profile-name">{{currentStudent.name}}</text>
                </view>
                <text class="profile-id">ID: {{currentStudent.id}}</text>
              </view>
            </view>
          </view>

          <!-- 当前班级卡片区域 - 始终显示 -->
          <view class="current-class-card{{isLoggedIn && currentClasses.length > 0 ? '' : ' empty'}}">
            <!-- 未登录状态 -->
            <view wx:if="{{!isLoggedIn}}" class="class-card-empty-content" bindtap="onLoginTap" hover-class="is-pressed" hover-stay-time="120">
              <text class="empty-text">登录后查看班级信息</text>
            </view>
            <!-- 已登录但未加入班级 -->
            <view wx:elif="{{currentClasses.length === 0}}" class="class-card-empty-content">
              <text class="empty-text">暂未加入班级</text>
            </view>
            <!-- 已登录且有班级 -->
            <block wx:else>
              <view class="class-card-header">
                <view class="class-status-dot"></view>
                <text class="class-card-name">{{currentClasses[0].displayName}}</text>
              </view>
              <text class="class-card-schedule">{{currentClasses[0].progressText}} {{currentClasses[0].displaySchedule}}</text>
              <view class="class-card-action" bindtap="onClassScheduleTap" hover-class="is-pressed" hover-stay-time="120">
                <image class="class-card-icon" src="/images/icons/calendar-white.svg" mode="aspectFit" />
                <text class="class-card-btn-text">课表</text>
              </view>
            </block>
          </view>
        </view>

        <!-- 课程服务 -->
        <view class="section">
          <view class="service-card">
          <view class="service-grid">
            <view
              class="service-item"
              wx:for="{{mockData.services}}"
              wx:key="id"
              data-id="{{item.id}}"
              bindtap="onServiceTap"
              hover-class="is-pressed"
              hover-stay-time="120"
            >
              <view class="service-icon-wrapper">
                <view class="service-icon-bg"></view>
                <image class="service-icon" src="{{item.icon}}" mode="aspectFit" />
              </view>
              <text class="service-text">{{item.label}}</text>
            </view>
          </view>
          </view>
        </view>

        <!-- 设置入口 -->
        <view class="settings-entry" bindtap="onSettingsTap" hover-class="is-pressed" hover-stay-time="120">
          <view class="settings-left">
            <view class="settings-icon-wrapper">
              <image class="settings-icon" src="/images/icons/settings.svg" mode="aspectFit" />
            </view>
            <text class="settings-text">设置</text>
          </view>
          <text class="arrow">›</text>
        </view>
      </view>
    </scroll-view>
  </view>
</view>

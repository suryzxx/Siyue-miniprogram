/* 课表页面样式 */
page {
  height: 100vh;
  background: linear-gradient(180deg, #f8f4ff 0%, #faf8fc 30%, #f7f8fa 100%);
  color: #1f2d3d;
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.page-container {
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* Tab 切换栏 */
.tab-bar {
  display: flex;
  background: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
  padding: 0 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(31, 45, 61, 0.05);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: #888888;
  position: relative;
  transition: all 0.3s;
}

.tab-item.active {
  color: #8b5cf6;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: linear-gradient(135deg, #a78bfa 0%, #8b5cf6 100%);
  border-radius: 3rpx;
}

.scrollarea {
  flex: 1;
}

.content {
  padding: 24rpx 24rpx 40rpx;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
  color: #999999;
}

.section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  color: #1f2d3d;
  font-weight: 600;
  margin-bottom: 16rpx;
}

/* 统计卡片 */
.stats-card {
  background: linear-gradient(135deg, #ffffff 0%, #faf8fc 100%);
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  display: flex;
  justify-content: space-around;
  box-shadow: 0 12rpx 32rpx rgba(139, 92, 246, 0.12);
  border: 1rpx solid rgba(139, 92, 246, 0.1);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #8b5cf6 0%, #a78bfa 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stat-label {
  font-size: 24rpx;
  color: #888888;
}

/* 考勤记录列表 */
.record-list {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 32rpx rgba(31, 45, 61, 0.1);
}

.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: all 0.2s ease;
}

.record-item:last-child {
  border-bottom: none;
}

.record-item:active {
  background: #faf8fc;
}

.record-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.record-date {
  font-size: 28rpx;
  color: #1f2d3d;
  font-weight: 600;
}

.record-weekday {
  font-size: 22rpx;
  color: #888888;
}

.record-session {
  font-size: 22rpx;
  color: #8b5cf6;
  font-weight: 500;
}

.record-right {
  display: flex;
  align-items: center;
}

.record-status {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.record-status.present {
  background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
  color: #059669;
}

.record-status.absent {
  background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
  color: #dc2626;
}

.record-status.late {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  color: #d97706;
}

.record-status.leave {
  background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%);
  color: #4f46e5;
}

/* 课表列表 */
.schedule-list {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 32rpx rgba(31, 45, 61, 0.1);
}

.schedule-item {
  display: flex;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: all 0.2s ease;
}

.schedule-item:last-child {
  border-bottom: none;
}

.schedule-item:active {
  background: #faf8fc;
}

.schedule-date {
  width: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-right: 1rpx solid #f0f0f0;
  padding-right: 20rpx;
  margin-right: 20rpx;
}

.date-day {
  font-size: 28rpx;
  color: #1f2d3d;
  font-weight: 600;
}

.date-weekday {
  font-size: 22rpx;
  color: #888888;
  margin-top: 4rpx;
}

.schedule-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.schedule-session {
  font-size: 22rpx;
  color: #8b5cf6;
  font-weight: 500;
}

.schedule-topic {
  font-size: 28rpx;
  color: #1f2d3d;
  font-weight: 600;
}

.schedule-time {
  font-size: 24rpx;
  color: #888888;
}

.schedule-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  align-self: flex-start;
  margin-top: 4rpx;
  font-weight: 500;
}

.schedule-status.completed {
  background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
  color: #059669;
}

.schedule-status.upcoming {
  background: linear-gradient(135deg, #ede9fe 0%, #ddd6fe 100%);
  color: #7c3aed;
}

.schedule-status.cancelled {
  background: #f3f4f6;
  color: #9ca3af;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 80rpx 0;
  color: #999999;
  font-size: 28rpx;
  gap: 16rpx;
}

.empty image {
  width: 160rpx;
  height: 160rpx;
  opacity: 0.5;
}

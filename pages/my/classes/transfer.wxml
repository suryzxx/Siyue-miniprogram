<view class="page">
  <custom-navbar
    center-text="转班"
    show-left="{{true}}"
    show-right="{{false}}"
    show-back="{{true}}"
    left-text="返回"
  />

  <view class="page-container" style="padding-top: {{navBarHeight}}px;">
    <scroll-view class="scrollarea" scroll-y>
      <view class="content">
        <!-- 加载中 -->
        <view class="loading" wx:if="{{loading}}">
          <text>加载中...</text>
        </view>

        <block wx:else>
          <!-- 当前班级 -->
          <view class="section">
            <view class="section-title">当前班级</view>
            <view class="current-class-card">
              <view class="class-header">
                <text class="class-name">{{currentClass.displayName}}</text>
              </view>
              <view class="class-info-row">
                <text class="info-label">校区：</text>
                <text class="info-value">{{currentClass.displayCampus}}</text>
              </view>
              <view class="class-info-row">
                <text class="info-label">老师：</text>
                <text class="info-value">{{currentClass.displayTeacher}}</text>
              </view>
              <view class="class-info-row">
                <text class="info-label">时间：</text>
                <text class="info-value">{{currentClass.displaySchedule}}</text>
              </view>
              <view class="class-info-row">
                <text class="info-label">进度：</text>
                <text class="info-value progress">{{currentClass.progressText}}</text>
              </view>
            </view>
          </view>

          <!-- 申请结果 -->
          <view class="section" wx:if="{{applyResult}}">
            <view class="result-card success">
              <view class="result-icon">✓</view>
              <view class="result-content">
                <text class="result-title">转班申请已提交</text>
                <text class="result-desc">等待管理员审核</text>
                <view class="result-detail">
                  <text class="detail-label">转入班级：</text>
                  <text class="detail-value">{{applyResult.targetClassName}}</text>
                </view>
                <view class="result-detail">
                  <text class="detail-label">申请时间：</text>
                  <text class="detail-value">{{applyResult.applyTime}}</text>
                </view>
              </view>
            </view>
          </view>

          <!-- 可转入班级列表 -->
          <view class="section">
            <view class="section-title">可转入班级</view>
            <view class="class-list" wx:if="{{transferOptions.length > 0}}">
              <view 
                class="transfer-card {{selectedOption && selectedOption.id === item.id ? 'is-selected' : ''}}"
                wx:for="{{transferOptions}}"
                wx:key="id"
                data-item="{{item}}"
                bindtap="onOptionSelect"
                hover-class="is-pressed"
                hover-stay-time="120"
              >
                <view class="card-header">
                  <text class="class-name">{{item.displayName}}</text>
                  <text class="seats-tag {{item.remaining > 0 ? 'has-seats' : 'no-seats'}}">
                    {{item.seatsText}}
                  </text>
                </view>
                <view class="card-info">
                  <text class="info-text">{{item.displayCampus}}</text>
                  <text class="info-text">{{item.displayTeacher}}</text>
                  <text class="info-text">{{item.displaySchedule}}</text>
                  <text class="info-text progress">{{item.progressText}}</text>
                </view>
                <view class="card-footer">
                  <text class="fee-text">{{item.feeText}}</text>
                </view>
              </view>
            </view>
            <view class="empty-tip" wx:else>
              <text>暂无可转入的班级</text>
            </view>
          </view>

          <!-- 转班原因 -->
          <view class="section" wx:if="{{selectedOption && !applyResult}}">
            <view class="section-title">转班原因</view>
            <textarea 
              class="reason-input"
              placeholder="请输入转班原因"
              value="{{reason}}"
              bindinput="onReasonInput"
              maxlength="200"
            />
          </view>

          <!-- 提交按钮 -->
          <view class="submit-section" wx:if="{{selectedOption && !applyResult}}">
            <button class="submit-btn {{!reason.trim() ? 'disabled' : ''}}" bindtap="onSubmit" disabled="{{!reason.trim() || submitting}}">
              {{submitting ? '提交中...' : '确认转班'}}
            </button>
          </view>
        </block>
      </view>
    </scroll-view>
  </view>
</view>

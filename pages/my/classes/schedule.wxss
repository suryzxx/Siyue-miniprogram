page {
  height: 100vh;
  background: #f5f6f8;
  color: #1f2d3d;
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.page-container {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.scrollarea {
  flex: 1;
}

.content {
  padding: 24rpx 24rpx 40rpx;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
  color: #999999;
}

.section {
  margin-bottom: 24rpx;
}

.schedule-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.schedule-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 8rpx 16rpx rgba(31, 45, 61, 0.06);
}

.schedule-date {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 80rpx;
}

.date-day {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2d3d;
}

.date-weekday {
  font-size: 22rpx;
  color: #888888;
  margin-top: 4rpx;
}

.schedule-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.schedule-session {
  font-size: 22rpx;
  color: #6b4ce6;
  font-weight: 500;
}

.schedule-topic {
  font-size: 26rpx;
  color: #1f2d3d;
  font-weight: 500;
}

.schedule-time {
  font-size: 22rpx;
  color: #888888;
}

.schedule-status {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  align-self: flex-start;
  margin-top: 6rpx;
}

.schedule-status.completed {
  background: #d1fae5;
  color: #10b981;
}

.schedule-status.upcoming {
  background: #e0e7ff;
  color: #6366f1;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999999;
}

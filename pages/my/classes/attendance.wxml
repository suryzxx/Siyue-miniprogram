<view class="page">
  <custom-navbar
    center-text="考勤课表"
    show-left="{{true}}"
    show-right="{{false}}"
    show-back="{{true}}"
    left-text="返回"
  />

  <view class="page-container" style="padding-top: {{navBarHeight}}px;">
    <!-- Tab 切换 -->
    <view class="tab-bar">
      <view class="tab-item {{activeTab === 'attendance' ? 'active' : ''}}" bindtap="onTabChange" data-tab="attendance">考勤</view>
      <view class="tab-item {{activeTab === 'schedule' ? 'active' : ''}}" bindtap="onTabChange" data-tab="schedule">课表</view>
    </view>

    <scroll-view class="scrollarea" scroll-y>
      <view class="content">
        <!-- 加载中 -->
        <view class="loading" wx:if="{{loading}}">
          <text>加载中...</text>
        </view>

        <block wx:else>
          <!-- 考勤 Tab -->
          <block wx:if="{{activeTab === 'attendance'}}">
            <!-- 统计信息 -->
            <view class="section">
              <view class="stats-card">
                <view class="stat-item">
                  <text class="stat-value">{{statistics.presentCount}}</text>
                  <text class="stat-label">出勤</text>
                </view>
                <view class="stat-item">
                  <text class="stat-value">{{statistics.absentCount}}</text>
                  <text class="stat-label">缺勤</text>
                </view>
                <view class="stat-item">
                  <text class="stat-value">{{statistics.lateCount}}</text>
                  <text class="stat-label">迟到</text>
                </view>
                <view class="stat-item">
                  <text class="stat-value">{{statistics.leaveCount}}</text>
                  <text class="stat-label">请假</text>
                </view>
              </view>
            </view>

            <!-- 考勤列表 -->
            <view class="section">
              <view class="section-title">考勤明细</view>
              <view class="record-list" wx:if="{{attendanceRecords.length > 0}}">
                <view class="record-item" wx:for="{{attendanceRecords}}" wx:key="date" data-index="{{index}}" bindtap="onRecordTap">
                  <view class="record-left">
                    <text class="record-date">{{item.dateText}}</text>
                    <text class="record-weekday">{{item.weekdayText}}</text>
                    <text class="record-session">{{item.sessionText}}</text>
                  </view>
                  <view class="record-right">
                    <text class="record-status {{item.statusClass}}">{{item.statusText}}</text>
                  </view>
                </view>
              </view>
              <view class="empty" wx:else>
                <text>暂无考勤记录</text>
              </view>
            </view>
          </block>

          <!-- 课表 Tab -->
          <block wx:if="{{activeTab === 'schedule'}}">
            <view class="section" wx:if="{{scheduleRecords.length > 0}}">
              <view class="schedule-list">
                <view class="schedule-item" wx:for="{{scheduleRecords}}" wx:key="date">
                  <view class="schedule-date">
                    <text class="date-day">{{item.dateText}}</text>
                    <text class="date-weekday">{{item.weekdayText}}</text>
                  </view>
                  <view class="schedule-content">
                    <text class="schedule-session">{{item.sessionText}}</text>
                    <text class="schedule-topic">{{item.topic}}</text>
                    <text class="schedule-time">{{item.timeText}}</text>
                    <text class="schedule-status {{item.scheduleStatusClass}}">{{item.scheduleStatusText}}</text>
                  </view>
                </view>
              </view>
            </view>
            <view class="empty" wx:else>
              <text>暂无课表信息</text>
            </view>
          </block>
        </block>
      </view>
    </scroll-view>
  </view>
</view>

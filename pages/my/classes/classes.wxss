/* 页面基础样式 */
page {
  width: 100%;
  min-height: 100vh;
  background-color: #f6f6f8;
  color: #1f2d3d;
}

.page {
  width: 100%;
  min-height: 100vh;
  background-color: #f6f6f8;
}

.page-container {
  width: 100%;
  min-height: 100vh;
}

/* Tab 导航 */
.tabs-nav {
  display: flex;
  background: #ffffff;
  border-bottom: 1rpx solid #f1f5f9;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 32rpx 0;
  border-bottom: 4rpx solid transparent;
}

.tab-item.active {
  border-bottom-color: #9e8ef1;
}

.tab-text {
  font-size: 28rpx;
  color: #64748b;
}

.tab-item.active .tab-text {
  color: #9e8ef1;
  font-weight: 500;
}

/* 滚动区域 */
.scrollarea {
  width: 100%;
  min-height: 100vh;
}

.content {
  padding: 32rpx;
  padding-bottom: 120rpx;
}

.tab-content {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

/* 班级列表 */
.class-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 班级卡片 */
.class-card {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(31, 45, 61, 0.04);
  border: 1rpx solid rgba(158, 142, 241, 0.2);
}

.class-card.completed,
.class-card.unstarted {
  border-color: #f1f5f9;
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 32rpx;
}

.header-left {
  flex: 1;
}

.title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.class-name {
  font-size: 36rpx;
  font-weight: 500;
  color: #1f2d3d;
}

.class-info {
  font-size: 26rpx;
  color: #64748b;
  display: block;
}

/* 右上角切换按钮 */
.switch-btn-header {
  padding: 12rpx 32rpx;
  background: rgba(158, 142, 241, 0.1);
  border-radius: 16rpx;
  flex-shrink: 0;
}

.switch-btn-header text {
  font-size: 26rpx;
  font-weight: 500;
  color: #9e8ef1;
}

/* 状态标签 */
.status-tag {
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
}

.status-tag.completed {
  background: #f1f5f9;
  color: #64748b;
}

.status-tag.unstarted {
  background: #f1f5f9;
  color: #64748b;
}

/* 卡片内容 */
.card-body {
  padding: 0 32rpx 32rpx;
}

/* 信息行 */
.info-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

/* 信息网格（已完成班级：两列布局） */
.info-grid {
  display: grid;
  grid-template-columns: 1.4fr 1fr;
  gap: 16rpx;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.info-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.info-text {
  font-size: 24rpx;
  color: #64748b;
}

/* 学习进度 */
.progress-section {
  padding: 16rpx 32rpx 32rpx;
  border-top: 1rpx solid #f6f6f8;
  margin-top: 16rpx;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.progress-label {
  font-size: 24rpx;
  font-weight: 500;
  color: #9e8ef1;
}

.progress-value {
  font-size: 24rpx;
  color: #64748b;
}

.progress-bar {
  height: 12rpx;
  width: 100%;
  background: rgba(158, 142, 241, 0.1);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #9e8ef1;
  border-radius: 6rpx;
}

/* 当前班级卡片（转班/调课tab） */
.current-class-card {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(31, 45, 61, 0.04);
  border: 1rpx solid rgba(158, 142, 241, 0.2);
}

.card-inner {
  padding: 32rpx;
}

.card-header-row {
  margin-bottom: 16rpx;
}

.card-body-row {
  margin-bottom: 8rpx;
}

/* 分区标题 */
.section {
  margin-top: 16rpx;
}

.section-title {
  font-size: 24rpx;
  color: #64748b;
  display: block;
  margin-bottom: 24rpx;
}

/* 讲次选择区域 */
.session-section {
  margin-top: 16rpx;
  padding: 0 32rpx;
}

.session-scroll {
  width: 100%;
  white-space: nowrap;
}

.session-list {
  display: flex;
  gap: 16rpx;
  padding-bottom: 16rpx;
}

.session-item {
  flex-shrink: 0;
  width: 160rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1rpx solid #f1f5f9;
  display: flex;
  align-items: center;
  justify-content: center;
}

.session-item text {
  font-size: 28rpx;
  font-weight: 500;
  color: #64748b;
}

.session-item.active {
  background: linear-gradient(135deg, #9e8ef1 0%, #7e6ef1 100%);
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(158, 142, 241, 0.3);
}

.session-item.active text {
  color: #ffffff;
}

/* 转班列表 */
.transfer-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.transfer-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(31, 45, 61, 0.04);
  border: 1rpx solid #f1f5f9;
}

.transfer-card.disabled {
  opacity: 0.6;
}

.transfer-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.transfer-info {
  flex: 1;
}

.transfer-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1f2d3d;
  display: block;
}

.transfer-detail {
  font-size: 24rpx;
  color: #64748b;
  display: block;
  margin-top: 8rpx;
}

/* 名额标签 */
.quota-tag {
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.quota-tag.available {
  background: rgba(16, 185, 129, 0.1);
  color: #10b981;
}

.quota-tag.full {
  background: #f1f5f9;
  color: #64748b;
}

.transfer-schedule {
  font-size: 24rpx;
  color: #475569;
  margin-bottom: 24rpx;
}

.transfer-action {
  padding-top: 24rpx;
  border-top: 1rpx solid #f6f6f8;
}

.transfer-btn {
  width: 100%;
  padding: 20rpx 0;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #9e8ef1 0%, #7e6ef1 100%);
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(158, 142, 241, 0.3);
}

.transfer-btn text {
  font-size: 28rpx;
  font-weight: 500;
  color: #ffffff;
}

.transfer-btn.disabled {
  background: #e2e8f0;
  box-shadow: none;
}

.transfer-btn.disabled text {
  color: #94a3b8;
}

/* 调课列表 */
.adjust-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.adjust-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(31, 45, 61, 0.04);
  border: 1rpx solid #f1f5f9;
}

.adjust-card.disabled {
  opacity: 0.6;
}

.adjust-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.adjust-info {
  flex: 1;
}

.adjust-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1f2d3d;
  display: block;
  margin-bottom: 12rpx;
}

.adjust-detail-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  flex-wrap: wrap;
}

.adjust-detail-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.detail-icon {
  width: 24rpx;
  height: 24rpx;
  flex-shrink: 0;
}

.adjust-detail-item text {
  font-size: 24rpx;
  color: #64748b;
}

.adjust-action {
  padding-top: 24rpx;
  border-top: 1rpx solid #f6f6f8;
}

.adjust-btn {
  width: 100%;
  padding: 20rpx 0;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #9e8ef1 0%, #7e6ef1 100%);
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(158, 142, 241, 0.3);
}

.adjust-btn text {
  font-size: 28rpx;
  font-weight: 500;
  color: #ffffff;
}

.adjust-btn.disabled {
  background: #e2e8f0;
  box-shadow: none;
}

.adjust-btn.disabled text {
  color: #94a3b8;
}

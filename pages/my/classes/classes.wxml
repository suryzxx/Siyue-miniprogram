<view class="page">
  <!-- 顶部导航 -->
  <custom-navbar
    center-text="我的班级"
    show-left="{{true}}"
    show-right="{{false}}"
    show-back="{{true}}"
    left-icon="/images/icons/back.svg"
  />

  <view class="page-container" style="padding-top: {{navBarHeight}}px;">
    <!-- Tab 导航 -->
    <view class="tabs-nav">
      <view 
        class="tab-item {{currentTab === 0 ? 'active' : ''}}" 
        data-index="0" 
        bindtap="onTabChange"
      >
        <text class="tab-text">班级列表</text>
      </view>
      <view 
        class="tab-item {{currentTab === 1 ? 'active' : ''}}" 
        data-index="1" 
        bindtap="onTabChange"
      >
        <text class="tab-text">转班</text>
      </view>
      <view 
        class="tab-item {{currentTab === 2 ? 'active' : ''}}" 
        data-index="2" 
        bindtap="onTabChange"
      >
        <text class="tab-text">调课</text>
      </view>
    </view>

    <scroll-view class="scrollarea" scroll-y>
      <view class="content">
        
        <!-- Tab 0: 班级列表 -->
        <view class="tab-content" wx:if="{{currentTab === 0}}">
          <view class="class-list">
            <view class="class-card {{item.status}}" wx:for="{{classList}}" wx:key="id">
              <!-- 卡片头部 -->
              <view class="card-header">
                <view class="header-left">
                  <view class="title-row">
                    <text class="class-name">{{item.name}}</text>
                    <view class="status-tag {{item.status}}" wx:if="{{item.status !== 'active'}}">
                      <text>{{item.status === 'completed' ? '已结课' : '未开课'}}</text>
                    </view>
                  </view>
                  <text class="class-info">{{item.campus}} · {{item.teacher}}</text>
                </view>
                <!-- 切换按钮在右上角（仅已结课班级） -->
                <view class="switch-btn-header" wx:if="{{item.status === 'completed'}}" bindtap="onSwitchClass" data-item="{{item}}">
                  <text>切换</text>
                </view>
              </view>
              
              <!-- 卡片内容 -->
              <view class="card-body">
                <!-- 已完成班级：时间和讲次在同一行 -->
                <view class="info-grid" wx:if="{{item.status === 'completed'}}">
                  <view class="info-item">
                    <image class="info-icon" src="/images/icons/calendar.svg" mode="aspectFit" />
                    <text class="info-text">{{item.startDate}}-{{item.endDate}}</text>
                  </view>
                  <view class="info-item">
                    <image class="info-icon" src="/images/icons/check.svg" mode="aspectFit" />
                    <text class="info-text">共{{item.totalSessions}}讲 · 已完成</text>
                  </view>
                </view>
                <!-- 进行中班级 -->
                <block wx:if="{{item.status === 'active'}}">
                  <view class="info-row">
                    <image class="info-icon" src="/images/icons/calendar.svg" mode="aspectFit" />
                    <text class="info-text">{{item.startDate}}-{{item.endDate}}</text>
                  </view>
                  <view class="info-row" wx:if="{{item.schedule}}">
                    <image class="info-icon" src="/images/icons/time.svg" mode="aspectFit" />
                    <text class="info-text">{{item.schedule}}</text>
                  </view>
                </block>
                <!-- 未开课班级 -->
                <block wx:if="{{item.status === 'unstarted'}}">
                  <view class="info-row">
                    <image class="info-icon" src="/images/icons/calendar.svg" mode="aspectFit" />
                    <text class="info-text">{{item.startDate}}-{{item.endDate}}</text>
                  </view>
                  <view class="info-row" wx:if="{{item.schedule}}">
                    <image class="info-icon" src="/images/icons/time.svg" mode="aspectFit" />
                    <text class="info-text">{{item.schedule}}</text>
                  </view>
                </block>
              </view>

              <!-- 学习进度（仅进行中班级） -->
              <view class="progress-section" wx:if="{{item.status === 'active'}}">
                <view class="progress-header">
                  <text class="progress-label">学习进度</text>
                  <text class="progress-value">第{{item.currentSession}}讲</text>
                </view>
                <view class="progress-bar">
                  <view class="progress-fill" style="width: {{item.currentSession / item.totalSessions * 100}}%"></view>
                </view>
              </view>
            </view>
          </view>
        </view>

        <!-- Tab 1: 转班 -->
        <view class="tab-content" wx:if="{{currentTab === 1}}">
          <!-- 当前班级信息 -->
          <view class="current-class-card" wx:if="{{currentClass}}">
            <view class="card-inner">
              <view class="card-header-row">
                <view>
                  <text class="class-name">{{currentClass.name}}</text>
                  <text class="class-info">{{currentClass.campus}} · {{currentClass.teacher}}</text>
                </view>
              </view>
              <view class="card-body-row">
                <view class="info-row">
                  <image class="info-icon" src="/images/icons/calendar.svg" mode="aspectFit" />
                  <text class="info-text">{{currentClass.startDate}}-{{currentClass.endDate}}</text>
                </view>
                <view class="info-row">
                  <image class="info-icon" src="/images/icons/time.svg" mode="aspectFit" />
                  <text class="info-text">{{currentClass.schedule}}</text>
                </view>
              </view>
              <view class="progress-section">
                <view class="progress-header">
                  <text class="progress-label">学习进度</text>
                  <text class="progress-value">第{{currentClass.currentSession}}讲</text>
                </view>
                <view class="progress-bar">
                  <view class="progress-fill" style="width: {{currentClass.currentSession / currentClass.totalSessions * 100}}%"></view>
                </view>
              </view>
            </view>
          </view>

          <!-- 可选转入班级 -->
          <view class="section">
            <text class="section-title">可选转入班级</text>
            <view class="transfer-list">
              <view class="transfer-card {{item.remaining === 0 ? 'disabled' : ''}}" wx:for="{{transferList}}" wx:key="id">
                <view class="transfer-header">
                  <view class="transfer-info">
                    <text class="transfer-name">{{item.name}}</text>
                    <text class="transfer-detail">{{item.campus}} · {{item.teacher}}</text>
                  </view>
                  <view class="quota-tag {{item.remaining > 0 ? 'available' : 'full'}}">
                    <text>{{item.remaining > 0 ? '剩余' + item.remaining + '名额' : '已满员'}}</text>
                  </view>
                </view>
                <view class="transfer-schedule">
                  <text>{{item.schedule}}</text>
                </view>
                <view class="transfer-action">
                  <view 
                    class="transfer-btn {{item.remaining === 0 ? 'disabled' : ''}}" 
                    bindtap="onTransfer" 
                    data-item="{{item}}"
                  >
                    <text>{{item.remaining === 0 ? '暂无名额' : '立即转班'}}</text>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </view>

        <!-- Tab 2: 调课 -->
        <view class="tab-content" wx:if="{{currentTab === 2}}">
          <!-- 当前班级信息 -->
          <view class="current-class-card" wx:if="{{currentClass}}">
            <view class="card-inner">
              <view class="card-header-row">
                <view>
                  <text class="class-name">{{currentClass.name}}</text>
                  <text class="class-info">{{currentClass.campus}} · {{currentClass.teacher}}</text>
                </view>
              </view>
              <view class="card-body-row">
                <view class="info-row">
                  <image class="info-icon" src="/images/icons/calendar.svg" mode="aspectFit" />
                  <text class="info-text">{{currentClass.startDate}}-{{currentClass.endDate}}</text>
                </view>
                <view class="info-row">
                  <image class="info-icon" src="/images/icons/time.svg" mode="aspectFit" />
                  <text class="info-text">{{currentClass.schedule}}</text>
                </view>
              </view>
              <view class="progress-section">
                <view class="progress-header">
                  <text class="progress-label">学习进度</text>
                  <text class="progress-value">第{{currentClass.currentSession}}讲</text>
                </view>
                <view class="progress-bar">
                  <view class="progress-fill" style="width: {{currentClass.currentSession / currentClass.totalSessions * 100}}%"></view>
                </view>
              </view>
            </view>
          </view>

          <!-- 选择讲次 -->
          <view class="session-section">
            <text class="section-title">选择讲次</text>
            <scroll-view class="session-scroll" scroll-x>
              <view class="session-list">
                <view 
                  class="session-item {{currentSessionIndex === index ? 'active' : ''}}" 
                  wx:for="{{sessionList}}" 
                  wx:key="index"
                  bindtap="onSelectSession"
                  data-index="{{index}}"
                >
                  <text>第{{item}}讲</text>
                </view>
              </view>
            </scroll-view>
          </view>

          <!-- 可选调课班级 -->
          <view class="section">
            <text class="section-title">可选调课班级</text>
            <view class="adjust-list">
              <view class="adjust-card {{item.remaining === 0 ? 'disabled' : ''}}" wx:for="{{adjustList}}" wx:key="id">
                <view class="adjust-header">
                  <view class="adjust-info">
                    <text class="adjust-name">{{item.name}}</text>
                    <view class="adjust-detail-row">
                      <view class="adjust-detail-item">
                        <image class="detail-icon" src="/images/icons/location.svg" mode="aspectFit" />
                        <text>{{item.campus}}</text>
                      </view>
                      <view class="adjust-detail-item">
                        <image class="detail-icon" src="/images/icons/teacher.svg" mode="aspectFit" />
                        <text>{{item.teacher}}</text>
                      </view>
                      <view class="adjust-detail-item">
                        <image class="detail-icon" src="/images/icons/time.svg" mode="aspectFit" />
                        <text>{{item.schedule}}</text>
                      </view>
                    </view>
                  </view>
                  <view class="quota-tag {{item.remaining > 0 ? 'available' : 'full'}}">
                    <text>{{item.remaining > 0 ? '剩余' + item.remaining + '名额' : '已满员'}}</text>
                  </view>
                </view>
                <view class="adjust-action">
                  <view 
                    class="adjust-btn {{item.remaining === 0 ? 'disabled' : ''}}" 
                    bindtap="onAdjust" 
                    data-item="{{item}}"
                  >
                    <text>{{item.remaining === 0 ? '暂无名额' : '选择此课次'}}</text>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </view>

      </view>
    </scroll-view>
  </view>
</view>

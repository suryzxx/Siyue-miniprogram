<view class="page">
  <custom-navbar
    center-text="调课"
    show-left="{{true}}"
    show-right="{{false}}"
    show-back="{{true}}"
    left-text="返回"
  />

  <view class="page-container" style="padding-top: {{navBarHeight}}px;">
    <scroll-view class="scrollarea" scroll-y>
      <view class="content">
        <!-- 加载中 -->
        <view class="loading" wx:if="{{loading}}">
          <text>加载中...</text>
        </view>

        <block wx:else>
          <!-- 当前班级 -->
          <view class="section">
            <view class="section-title">当前班级</view>
            <view class="current-class-card">
              <text class="class-name">{{currentClass.displayName}}</text>
              <text class="class-info">{{currentClass.displayCampus}} · {{currentClass.displayTeacher}}</text>
              <text class="class-schedule">{{currentClass.displaySchedule}}</text>
            </view>
          </view>

          <!-- 选择日期 -->
          <view class="section">
            <view class="section-title">选择调课日期</view>
            <picker mode="selector" range="{{dates}}" range-key="label" value="{{selectedDateIndex}}" bindchange="onDateChange">
              <view class="picker-btn">
                <text>{{selectedDateLabel || '请选择日期'}}</text>
                <text class="arrow">›</text>
              </view>
            </picker>
          </view>

          <!-- 可调课班级 -->
          <view class="section">
            <view class="section-title">可调课班级</view>
            <view class="class-list" wx:if="{{adjustOptions.length > 0}}">
              <view 
                class="adjust-card {{selectedOption && selectedOption.id === item.id ? 'is-selected' : ''}}"
                wx:for="{{adjustOptions}}"
                wx:key="id"
                data-index="{{index}}"
                bindtap="onOptionSelect"
              >
                <text class="class-name">{{item.displayName}}</text>
                <text class="class-info">{{item.displayCampus}} · {{item.displayTeacher}}</text>
                <text class="class-schedule">{{item.displaySchedule}}</text>
                <text class="seats-text">{{item.seatsText}}</text>
              </view>
            </view>
            <view class="empty-tip" wx:else>
              <text>该日期暂无可调课班级</text>
            </view>
          </view>

          <!-- 调课原因 -->
          <view class="section" wx:if="{{selectedOption}}">
            <view class="section-title">调课原因</view>
            <textarea class="reason-input" placeholder="请输入调课原因" value="{{reason}}" bindinput="onReasonInput" maxlength="200" />
          </view>

          <!-- 提交按钮 -->
          <view class="submit-section" wx:if="{{selectedOption}}">
            <button class="submit-btn" bindtap="onSubmit">确认调课</button>
          </view>
        </block>
      </view>
    </scroll-view>
  </view>
</view>

page {
  height: 100vh;
  background: #f5f6f8;
  color: #1f2d3d;
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.page-container {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.scrollarea {
  flex: 1;
}

.content {
  padding: 24rpx 24rpx 40rpx;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
  color: #999999;
}

.section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  color: #1f2d3d;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.current-class-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.class-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2d3d;
}

.class-info {
  font-size: 24rpx;
  color: #666666;
}

.class-schedule {
  font-size: 24rpx;
  color: #888888;
}

.picker-btn {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.arrow {
  color: #999999;
  font-size: 28rpx;
}

.class-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.adjust-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 2rpx solid transparent;
}

.adjust-card.is-selected {
  border-color: #6b4ce6;
  background: #faf5ff;
}

.seats-text {
  font-size: 22rpx;
  color: #10b981;
  margin-top: 8rpx;
}

.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #999999;
}

.reason-input {
  width: 100%;
  min-height: 200rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.submit-section {
  margin-top: 32rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #6b4ce6 0%, #8b5cf6 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 48rpx;
  border: none;
}

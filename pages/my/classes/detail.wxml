<view class="page">
  <custom-navbar
    center-text="班级详情"
    show-left="{{true}}"
    show-right="{{false}}"
    show-back="{{true}}"
    left-text="返回"
  />

  <view class="page-container" style="padding-top: {{navBarHeight}}px;">
    <scroll-view class="scrollarea" scroll-y>
      <view class="content">
        <!-- 加载中 -->
        <view class="loading" wx:if="{{loading}}">
          <text>加载中...</text>
        </view>

        <block wx:else>
          <!-- 班级信息卡片 -->
          <view class="section">
            <view class="class-card">
              <view class="card-title">{{classInfo.name}}</view>
              <view class="info-grid">
                <view class="info-row">
                  <view class="info-item">
                    <text class="info-label">产品类型</text>
                    <text class="info-value">{{classInfo.productTypeDisplay}}</text>
                  </view>
                  <view class="info-item">
                    <text class="info-label">班型</text>
                    <text class="info-value">{{classInfo.classType}}</text>
                  </view>
                </view>
                <view class="info-row">
                  <view class="info-item">
                    <text class="info-label">课程次数</text>
                    <text class="info-value">{{classInfo.sessionsText}}</text>
                  </view>
                  <view class="info-item">
                    <text class="info-label">剩余名额</text>
                    <text class="info-value remaining">{{classInfo.remainingText}}</text>
                  </view>
                </view>
                <view class="info-row">
                  <view class="info-item full-width">
                    <text class="info-label">上课时间</text>
                    <text class="info-value">{{classInfo.schedule}}</text>
                  </view>
                </view>
                <view class="info-row">
                  <view class="info-item full-width">
                    <text class="info-label">上课地点</text>
                    <text class="info-value">{{classInfo.location}}</text>
                  </view>
                </view>
              </view>
            </view>
          </view>

          <!-- 教师海报 -->
          <view class="section">
            <image class="teacher-poster" src="{{classInfo.teacherPoster}}" mode="widthFix" />
          </view>

          <!-- 教学大纲 -->
          <view class="section" wx:if="{{classInfo.syllabus && classInfo.syllabus.length > 0}}">
            <view class="section-title">教学大纲</view>
            <view class="syllabus-list">
              <view class="syllabus-item" wx:for="{{classInfo.syllabus}}" wx:key="week">
                <view class="syllabus-week">第{{item.week}}讲</view>
                <view class="syllabus-title">{{item.title}}</view>
                <view class="syllabus-time">{{item.time}}</view>
              </view>
            </view>
          </view>
        </block>
      </view>
    </scroll-view>
  </view>
</view>

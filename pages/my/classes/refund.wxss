page {
  height: 100vh;
  background: #f5f6f8;
  color: #1f2d3d;
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.page-container {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.scrollarea {
  flex: 1;
}

.content {
  padding: 24rpx 24rpx 40rpx;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
  color: #999999;
}

.section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  color: #1f2d3d;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.class-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  box-shadow: 0 10rpx 24rpx rgba(31, 45, 61, 0.08);
}

.class-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2d3d;
}

.class-info {
  font-size: 24rpx;
  color: #666666;
}

.class-schedule {
  font-size: 24rpx;
  color: #888888;
}

.refund-info-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(31, 45, 61, 0.08);
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row.highlight {
  background: #fffbeb;
  margin: 12rpx -24rpx -24rpx;
  padding: 16rpx 24rpx;
  border-radius: 0 0 16rpx 16rpx;
}

.info-label {
  font-size: 26rpx;
  color: #666666;
}

.info-value {
  font-size: 26rpx;
  color: #1f2d3d;
}

.info-value.price {
  font-size: 36rpx;
  font-weight: 600;
  color: #ef4444;
}

.reason-input {
  width: 100%;
  min-height: 200rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.submit-section {
  margin-top: 32rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #ef4444 0%, #f87171 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 48rpx;
  border: none;
}

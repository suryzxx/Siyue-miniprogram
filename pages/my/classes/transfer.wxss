page {
  height: 100vh;
  background: #f5f6f8;
  color: #1f2d3d;
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.page-container {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.scrollarea {
  flex: 1;
}

.content {
  padding: 24rpx 24rpx 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
  color: #999999;
}

/* Section */
.section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  color: #1f2d3d;
  font-weight: 600;
  margin-bottom: 16rpx;
}

/* 当前班级卡片 */
.current-class-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(31, 45, 61, 0.08);
}

.class-header {
  margin-bottom: 16rpx;
}

.class-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2d3d;
}

.class-info-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.info-label {
  font-size: 24rpx;
  color: #888888;
  width: 80rpx;
}

.info-value {
  font-size: 24rpx;
  color: #333333;
  flex: 1;
}

.info-value.progress {
  color: #6b4ce6;
  font-weight: 500;
}

/* 申请结果 */
.result-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 10rpx 24rpx rgba(31, 45, 61, 0.08);
}

.result-card.success {
  border-left: 6rpx solid #10b981;
}

.result-icon {
  width: 80rpx;
  height: 80rpx;
  background: #d1fae5;
  color: #10b981;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 20rpx;
}

.result-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.result-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2d3d;
}

.result-desc {
  font-size: 26rpx;
  color: #666666;
}

.result-detail {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.detail-label {
  font-size: 24rpx;
  color: #888888;
}

.detail-value {
  font-size: 24rpx;
  color: #333333;
}

/* 可转入班级列表 */
.class-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.transfer-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 16rpx rgba(31, 45, 61, 0.06);
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.transfer-card.is-selected {
  border-color: #6b4ce6;
  background: #faf5ff;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.seats-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.seats-tag.has-seats {
  background: #d1fae5;
  color: #10b981;
}

.seats-tag.no-seats {
  background: #fee2e2;
  color: #ef4444;
}

.card-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-bottom: 12rpx;
}

.info-text {
  font-size: 24rpx;
  color: #666666;
}

.info-text.progress {
  color: #6b4ce6;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.fee-text {
  font-size: 24rpx;
  color: #f59e0b;
  font-weight: 500;
}

/* 空提示 */
.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #999999;
  font-size: 26rpx;
}

/* 转班原因 */
.reason-input {
  width: 100%;
  min-height: 200rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  box-shadow: 0 8rpx 16rpx rgba(31, 45, 61, 0.06);
  box-sizing: border-box;
}

/* 提交按钮 */
.submit-section {
  margin-top: 32rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #6b4ce6 0%, #8b5cf6 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.submit-btn.disabled {
  background: #d1d5db;
  color: #9ca3af;
}

.is-pressed {
  opacity: 0.7;
}

/* pages/my/settings.wxss */

.page {
  width: 100%;
  min-height: 100vh;
  background-color: #f6f6f8;
}

.page-container {
  width: 100%;
  min-height: 100vh;
}

.scrollarea {
  width: 100%;
  min-height: 100vh;
}

.content {
  padding: 32rpx;
  padding-bottom: 120rpx;
}

/* Profile Preview */
.profile-preview {
  margin-bottom: 48rpx;
}

.profile-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  gap: 32rpx;
  border: 1rpx solid rgba(158, 142, 241, 0.1);
}

.profile-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background-color: rgba(158, 142, 241, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar-icon {
  width: 100%;
  height: 100%;
}

.profile-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.profile-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
  line-height: 1.4;
}

.profile-id {
  font-size: 28rpx;
  color: #9ca3af;
  line-height: 1.4;
}

/* Section */
.section {
  margin-bottom: 48rpx;
}

.section-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #9ca3af;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  padding-left: 8rpx;
  margin-bottom: 16rpx;
}

/* Menu Card */
.menu-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(158, 142, 241, 0.1);
}

.menu-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 32rpx;
  gap: 32rpx;
  position: relative;
}

.menu-item-active {
  background-color: #f9fafb;
}

.menu-item:not(:last-child)::after {
  content: '';
  position: absolute;
  left: 112rpx;
  right: 32rpx;
  bottom: 0;
  height: 1rpx;
  background-color: rgba(158, 142, 241, 0.1);
}

.menu-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  background-color: rgba(158, 142, 241, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-icon {
  width: 40rpx;
  height: 40rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: #1f2937;
}

.menu-arrow {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.4;
}

/* Logout Section */
.logout-section {
  margin-top: 64rpx;
}

.logout-btn {
  width: 100%;
  height: 104rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(158, 142, 241, 0.1);
}

.logout-btn-active {
  background-color: #fef2f2;
}

.logout-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #ef4444;
}

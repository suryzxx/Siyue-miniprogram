/* 页面样式 */
page {
  height: 100vh;
  background: #f6f6f8;
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f6f6f8;
}

.page-container {
  flex: 1;
  overflow: hidden;
}

.scrollarea {
  height: 100%;
}

.content {
  padding: 32rpx;
}

/* 文章容器 */
.article {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
}

/* 文章标题 */
.article-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 16rpx;
  text-align: center;
}

/* 文章元信息 */
.article-meta {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 48rpx;
  text-align: center;
}

/* 章节标题 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #374151;
  margin-top: 32rpx;
  margin-bottom: 16rpx;
}

/* 章节正文 */
.section-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: #6b7280;
  margin-bottom: 24rpx;
  text-align: justify;
}

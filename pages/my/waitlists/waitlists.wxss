/* 页面基础样式 */
page {
  width: 100%;
  min-height: 100vh;
  background-color: #f6f6f8;
  color: #1f2d3d;
}

.page {
  width: 100%;
  min-height: 100vh;
  background-color: #f6f6f8;
}

.page-container {
  width: 100%;
  min-height: 100vh;
}

.scrollarea {
  width: 100%;
  min-height: 100vh;
}

.content {
  padding: 32rpx;
  padding-bottom: 120rpx;
}

/* 加载中 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
  color: #999999;
}

.loading text {
  font-size: 28rpx;
  color: #999999;
}

/* 候补列表 */
.waitlist-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 候补卡片 */
.waitlist-card {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(31, 45, 61, 0.04);
  border: 1rpx solid rgba(158, 142, 241, 0.2);
  padding: 32rpx;
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.class-name {
  font-size: 36rpx;
  font-weight: 500;
  color: #1f2d3d;
}

/* 产品标签 */
.product-tag {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
}

.product-tag.system {
  background: rgba(158, 142, 241, 0.1);
  color: #9e8ef1;
}

.product-tag.special {
  background: rgba(255, 159, 67, 0.1);
  color: #ff9f43;
}

/* 状态标签 */
.status-tag {
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.status-tag.pending {
  background: rgba(158, 142, 241, 0.1);
  color: #9e8ef1;
}

.status-tag.notified {
  background: rgba(16, 185, 129, 0.1);
  color: #10b981;
}

.status-tag.confirmed {
  background: rgba(59, 130, 246, 0.1);
  color: #3b82f6;
}

.status-tag.expired {
  background: #f1f5f9;
  color: #64748b;
}

.status-tag.cancelled {
  background: rgba(239, 68, 68, 0.1);
  color: #ef4444;
}

/* 学生信息 */
.student-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
  padding: 12rpx 16rpx;
  background: #f6f6f8;
  border-radius: 12rpx;
}

.student-icon {
  width: 28rpx;
  height: 28rpx;
}

.student-name {
  font-size: 26rpx;
  color: #1f2d3d;
  font-weight: 500;
}

/* 排队位置 */
.position-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding: 16rpx 20rpx;
  background: rgba(158, 142, 241, 0.08);
  border-radius: 16rpx;
}

.position-label {
  font-size: 26rpx;
  color: #64748b;
}

.position-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #9e8ef1;
}

/* 信息行 */
.info-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.info-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.info-text {
  font-size: 24rpx;
  color: #64748b;
  flex: 1;
}

/* 通知提示 */
.notify-tip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background: rgba(16, 185, 129, 0.08);
  border-radius: 16rpx;
}

.notify-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.notify-text {
  font-size: 24rpx;
  color: #10b981;
  font-weight: 500;
}

/* 操作按钮 */
.action-row {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f6f6f8;
}

.action-btn {
  padding: 16rpx 32rpx;
  border-radius: 16rpx;
  text-align: center;
}

.action-btn text {
  font-size: 26rpx;
  font-weight: 500;
}

.action-btn.primary {
  background: linear-gradient(135deg, #9e8ef1 0%, #7e6ef1 100%);
  box-shadow: 0 4rpx 16rpx rgba(158, 142, 241, 0.3);
}

.action-btn.primary text {
  color: #ffffff;
}

.action-btn.cancel {
  background: rgba(158, 142, 241, 0.1);
}

.action-btn.cancel text {
  color: #9e8ef1;
}

.action-btn.ghost {
  background: transparent;
  border: 1rpx solid #9e8ef1;
}

.action-btn.ghost text {
  color: #9e8ef1;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 32rpx;
}

.empty-btn {
  padding: 24rpx 60rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #9e8ef1 0%, #7e6ef1 100%);
}

.empty-btn text {
  font-size: 28rpx;
  font-weight: 500;
  color: #ffffff;
}

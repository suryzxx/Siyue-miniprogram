<view class="page">
  <custom-navbar
    center-text="我的候补"
    show-left="{{true}}"
    show-right="{{false}}"
    show-back="{{true}}"
    left-icon="/images/icons/back.svg"
  />

  <view class="page-container" style="padding-top: {{navBarHeight}}px;">
    <scroll-view class="scrollarea" scroll-y>
      <view class="content">
        <!-- 加载中 -->
        <view class="loading" wx:if="{{loading}}">
          <text>加载中...</text>
        </view>

        <!-- 候补列表 -->
        <view class="waitlist-list" wx:elif="{{waitlists.length > 0}}">
          <view
            class="waitlist-card"
            wx:for="{{waitlists}}"
            wx:key="id"
          >
            <!-- 头部：班级名称和状态 -->
            <view class="card-header">
              <view class="header-left">
                <text class="class-name">{{item.className}}</text>
                <text class="product-tag {{item.productType}}">{{item.productTypeName}}</text>
              </view>
              <view class="status-tag {{item.status}}">{{item.statusLabel}}</view>
            </view>

            <!-- 学生信息 -->
            <view class="student-info">
              <image class="student-icon" src="/images/icons/teacher.svg" mode="aspectFit" />
              <text class="student-name">{{item.studentName}}</text>
            </view>

            <!-- 候补位置 -->
            <view class="position-row" wx:if="{{item.status === 'pending'}}">
              <text class="position-label">当前排队位置</text>
              <text class="position-value">第 {{item.position}} 位</text>
            </view>

            <!-- 上课时间 -->
            <view class="info-row">
              <image class="info-icon" src="/images/icons/calendar.svg" mode="aspectFit" />
              <text class="info-text">{{item.schedule}}</text>
            </view>

            <!-- 上课地点 -->
            <view class="info-row">
              <image class="info-icon" src="/images/icons/location.svg" mode="aspectFit" />
              <text class="info-text">{{item.location}}</text>
            </view>

            <!-- 通知提示 -->
            <view class="notify-tip" wx:if="{{item.status === 'notified'}}">
              <image class="notify-icon" src="/images/icons/bell.svg" mode="aspectFit" />
              <text class="notify-text">有空位啦！请尽快完成支付，先到先得</text>
            </view>

            <!-- 操作按钮 -->
            <view class="action-row">
              <view 
                class="action-btn cancel" 
                wx:if="{{item.status === 'pending' || item.status === 'notified'}}"
                data-id="{{item.id}}"
                bindtap="onCancelWaitlist"
              >
                <text>取消候补</text>
              </view>
              <view 
                class="action-btn primary" 
                wx:if="{{item.status === 'notified'}}"
                data-id="{{item.id}}"
                data-classid="{{item.classId}}"
                bindtap="onConfirmWaitlist"
              >
                <text>立即支付</text>
              </view>
              <view 
                class="action-btn ghost" 
                wx:if="{{item.status === 'expired' || item.status === 'cancelled'}}"
                data-classid="{{item.classId}}"
                bindtap="onViewClass"
              >
                <text>查看班级</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 空状态 -->
        <view class="empty" wx:else>
          <image class="empty-icon" src="/images/pic/empty.png" mode="aspectFit" />
          <text class="empty-text">暂无候补记录</text>
          <view class="empty-btn" bindtap="goToSelect">
            <text>去选课</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
</view>

page {
  height: 100vh;
  background: linear-gradient(180deg, #f8f4ff 0%, #f5f6f8 200rpx);
  color: #1f2d3d;
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.page-container {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.scrollarea {
  flex: 1;
}

.content {
  padding: 24rpx 24rpx 40rpx;
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
  color: #999999;
  font-size: 28rpx;
}

/* 班级列表 */
.class-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 班级卡片 */
.class-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(158, 142, 241, 0.08);
  transition: all 0.2s ease;
}

.class-card:active {
  transform: scale(0.98);
}

/* 卡片头部 */
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.class-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2d3d;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tag-group {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.tag {
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.tag-type {
  background: rgba(158, 142, 241, 0.1);
  color: #9e8ef1;
}

.tag-level {
  background: rgba(158, 142, 241, 0.1);
  color: #9e8ef1;
}





/* 卡片内容 */
.card-body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.info-icon {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon-svg {
  width: 32rpx;
  height: 32rpx;
  color: #9ca3af;
}

.info-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.4;
}

/* 老师行 */
.teacher-row {
  padding-top: 4rpx;
}

.teacher-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.teacher-name {
  font-size: 26rpx;
  color: #666666;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, #eef0f3, transparent);
  margin: 16rpx 0;
}

/* 卡片底部 */
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.status-wrap {
  flex: 1;
}

.class-status {
  font-size: 24rpx;
  font-weight: 500;
}

.class-status.is-remaining {
  color: #ef4444;
}



.class-status.is-full {
  color: #ff8c00;
}

.price-wrap {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.class-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff4d6a;
}

.class-unit {
  font-size: 22rpx;
  color: #999999;
}

/* 按下效果 */
.is-pressed {
  opacity: 0.85;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

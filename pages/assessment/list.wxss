/* 页面基础样式 */
page {
  width: 100%;
  min-height: 100vh;
  background-color: #f6f6f8;
  color: #1f2d3d;
}

.page {
  width: 100%;
  min-height: 100vh;
  background-color: #f6f6f8;
}

.page-container {
  width: 100%;
  min-height: 100vh;
}

/* Tab栏 */
.tabs {
  display: flex;
  background: #ffffff;
  border-bottom: 1rpx solid #f1f5f9;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 32rpx 0;
  border-bottom: 4rpx solid transparent;
}

.tab-item text {
  font-size: 28rpx;
  color: #64748b;
}

.tab-item.is-active {
  border-bottom-color: #9e8ef1;
}

.tab-item.is-active text {
  color: #9e8ef1;
  font-weight: 500;
}

/* 滚动区域 */
.scrollarea {
  flex: 1;
  width: 100%;
}

.content {
  padding: 32rpx;
  padding-bottom: 200rpx;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 28rpx;
  color: #64748b;
  margin-bottom: 32rpx;
}

.empty-btn {
  padding: 24rpx 48rpx;
  background: linear-gradient(135deg, #9e8ef1 0%, #7e6ef1 100%);
  border-radius: 48rpx;
}

.empty-btn text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
}

/* 列表 */
.list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 卡片 */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(31, 45, 61, 0.04);
  border: 1rpx solid rgba(158, 142, 241, 0.2);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f6f6f8;
}

.student-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #1f2d3d;
}

.status {
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

.status text {
  font-size: 22rpx;
  font-weight: 500;
}

.status-pending {
  background: rgba(251, 191, 36, 0.1);
}

.status-pending text {
  color: #f59e0b;
}

.status-completed {
  background: rgba(158, 142, 241, 0.1);
}

.status-completed text {
  color: #9e8ef1;
}

.status-cancelled {
  background: #f1f5f9;
}

.status-cancelled text {
  color: #64748b;
}

.card-body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.info-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.info-text {
  font-size: 26rpx;
  color: #64748b;
}

.level-text {
  color: #9e8ef1;
  font-weight: 500;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f6f6f8;
}

.create-time {
  font-size: 22rpx;
  color: #94a3b8;
}

.arrow-icon {
  width: 24rpx;
  height: 24rpx;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #64748b;
  font-size: 26rpx;
}

/* 浮动按钮 */
.fab {
  position: fixed;
  right: 32rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #9e8ef1 0%, #7e6ef1 100%);
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(158, 142, 241, 0.3);
}

.fab-icon {
  font-size: 48rpx;
  color: #ffffff;
}

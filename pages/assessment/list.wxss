/* 页面基础样式 */
page {
  width: 100%;
  min-height: 100vh;
  background-color: #f6f6f8;
  color: #1f2d3d;
}

.page {
  width: 100%;
  min-height: 100vh;
  background-color: #f6f6f8;
}

.page-container {
  width: 100%;
  min-height: 100vh;
}

/* 滚动区域 */
.scrollarea {
  flex: 1;
  width: 100%;
}

.content {
  padding: 32rpx;
  padding-bottom: 200rpx;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 28rpx;
  color: #64748b;
  margin-bottom: 32rpx;
}

.empty-btn {
  padding: 24rpx 48rpx;
  background: linear-gradient(135deg, #9e8ef1 0%, #7e6ef1 100%);
  border-radius: 48rpx;
}

.empty-btn text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
}

/* 列表 */
.list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 卡片 */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(31, 45, 61, 0.04);
  border: 1rpx solid rgba(158, 142, 241, 0.2);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f6f6f8;
}

.card-title-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #1f2d3d;
}

/* 状态标签样式 */
.status-tag {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
}

.status-tag text {
  font-size: 24rpx;
  font-weight: 500;
}

/* 待评测 - 黄色 */
.status-pending {
  background: rgba(251, 191, 36, 0.15);
}

.status-pending text {
  color: #f59e0b;
}

/* 已完成 - 紫色 */
.status-completed {
  background: rgba(158, 142, 241, 0.15);
}

.status-completed text {
  color: #9e8ef1;
}

/* 已取消 - 灰色 */
.status-cancelled {
  background: #f1f5f9;
}

.status-cancelled text {
  color: #94a3b8;
}

/* 取消预约按钮 */
.cancel-btn {
  padding: 12rpx 24rpx;
  background: #f1f5f9;
  border-radius: 8rpx;
  border: 1rpx solid #e2e8f0;
}

.cancel-btn text {
  font-size: 24rpx;
  color: #64748b;
}

.cancel-btn:active {
  background: #e2e8f0;
}

.card-body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.info-item .info-text {
  flex: 1;
}

.info-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.info-text {
  font-size: 26rpx;
  color: #1f2d3d;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #64748b;
  font-size: 26rpx;
}

/* 浮动按钮容器 */
.fab-container {
  position: fixed;
  right: 32rpx;
  bottom: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 20rpx;
}

/* 日历按钮 */
.fab-calendar {
  padding: 20rpx 32rpx;
  background: linear-gradient(135deg, #9e8ef1 0%, #7e6ef1 100%);
  border-radius: 50rpx;
  box-shadow: 0 8rpx 24rpx rgba(158, 142, 241, 0.3);
}

.fab-calendar-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 500;
}

/* 浮动按钮 */
.fab {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #9e8ef1 0%, #7e6ef1 100%);
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(158, 142, 241, 0.3);
}

.fab-icon {
  font-size: 48rpx;
  color: #ffffff;
}

<view class="page">
  <custom-navbar
    center-text="评测记录"
    show-left="{{true}}"
    show-right="{{false}}"
    show-back="{{true}}"
    left-icon="/images/icons/back.svg"
  />

  <view class="page-container" style="padding-top: {{navBarHeight}}px;">
    <scroll-view class="scrollarea" scroll-y enable-pull-down-refresh bindrefresherrefresh="onPullDownRefresh">
      <view class="content">
        <view class="empty" wx:if="{{!loading && list.length === 0}}">
          <image class="empty-icon" src="/images/pic/empty.png" mode="aspectFit" />
          <text class="empty-text">暂无评测记录</text>
        </view>

        <view class="list" wx:else>
          <view
            class="card"
            wx:for="{{list}}"
            wx:key="id"
          >
            <view class="card-header">
              <view class="card-title-row">
                <text class="card-title">评测状态：</text>
                <view class="status-tag status-{{item.statusName === '待到访' ? 'pending' : (item.statusName === '已完成' || item.statusName === '已评测') ? 'completed' : 'cancelled'}}">
                  <text>{{(item.statusName === '已完成' || item.statusName === '已评测') && item.resultLevel ? '已评测：' + item.resultLevel : item.statusName}}</text>
                </view>
              </view>
              <view class="cancel-btn" wx:if="{{item.statusName === '待到访'}}" catchtap="onCancelTap" data-id="{{item.id}}" data-index="{{index}}">
                <text>取消预约</text>
              </view>
            </view>
            <view class="card-body">
              <view class="info-item">
                <image class="info-icon" src="/images/icons/location.svg" mode="aspectFit" />
                <text class="info-text">{{item.campusName}} {{item.addressDetail}}</text>
              </view>
              <view class="info-item">
                <image class="info-icon" src="/images/icons/time.svg" mode="aspectFit" />
                <text class="info-text">{{item.formattedTime}}</text>
              </view>
            </view>
          </view>
        </view>

        <view class="loading" wx:if="{{loading}}">
          <text>加载中...</text>
        </view>
      </view>
    </scroll-view>

    <view class="fab-container">
      <view class="fab-calendar" bindtap="onGoCalendar">
        <text class="fab-calendar-text">+预约评测</text>
      </view>
    </view>
  </view>
</view>

<view class="page">
  <custom-navbar
    center-text="评测详情"
    show-left="{{true}}"
    show-right="{{false}}"
    show-back="{{true}}"
    left-text="返回"
  />

  <view class="page-container" style="padding-top: {{navBarHeight}}px;">
    <scroll-view class="scrollarea" scroll-y>
      <view class="content" wx:if="{{detail}}">
        <view class="status-banner status-{{detail.status}}">
          <text class="status-icon">{{detail.status === 'completed' ? '✓' : detail.status === 'pending' ? '⏳' : '✕'}}</text>
          <text class="status-text">{{detail.status === 'pending' ? '待评测' : detail.status === 'completed' ? '评测已完成' : '已取消'}}</text>
        </view>

        <view class="card">
          <view class="section-title">评测学生</view>
          <view class="info-row">
            <text class="info-label">学生姓名</text>
            <text class="info-value">{{detail.studentName}}</text>
          </view>
        </view>

        <view class="card">
          <view class="section-title">预约信息</view>
          <view class="info-row">
            <text class="info-label">校区</text>
            <text class="info-value">{{detail.campusName}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">地址</text>
            <text class="info-value">{{detail.campusAddress}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">预约日期</text>
            <text class="info-value">{{detail.bookDate}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">预约时间</text>
            <text class="info-value">{{detail.bookTime}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">预约时间</text>
            <text class="info-value sub">{{detail.createdAt}}</text>
          </view>
        </view>

        <view class="card" wx:if="{{detail.status === 'completed' && detail.resultLevel}}">
          <view class="section-title">评测结果</view>
          <view class="result-box">
            <text class="result-label">评测等级</text>
            <text class="result-level">{{detail.resultLevel}}</text>
          </view>
          <view class="result-tip" wx:if="{{detail.resultAt}}">
            评测完成时间：{{detail.resultAt}}
          </view>
          <view class="result-tip">
            评测等级有效期为3个月，请在有效期内完成报名
          </view>
        </view>

        <view class="card" wx:if="{{detail.teacherPhone}}">
          <view class="section-title">联系方式</view>
          <view class="contact-row">
            <view class="contact-info">
              <text class="contact-label">咨询电话</text>
              <text class="contact-phone">{{detail.teacherPhone}}</text>
            </view>
            <view class="contact-actions">
              <view class="contact-btn" bindtap="onCopyPhone">复制</view>
              <view class="contact-btn is-primary" bindtap="onCallTeacher">拨打</view>
            </view>
          </view>
        </view>

        <view class="btn-group" wx:if="{{detail.status === 'pending'}}">
          <view class="cancel-btn" bindtap="onCancel">取消预约</view>
        </view>

        <view class="btn-group" wx:if="{{detail.status === 'completed'}}">
          <view class="primary-btn" bindtap="onGoEnroll">去报名课程</view>
        </view>
      </view>

      <view class="loading" wx:if="{{loading}}">
        <text>加载中...</text>
      </view>
    </scroll-view>
  </view>
</view>

page {
  height: 100vh;
  background: #f5f6f8;
  color: #1f2d3d;
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.page-container {
  flex: 1;
  padding-bottom: 120rpx;
}

.scrollarea {
  height: 100%;
}

.content {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(31, 45, 61, 0.08);
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.course-title {
  font-size: 28rpx;
  font-weight: 600;
}

.course-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.student-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
}

.student-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.student-name {
  font-size: 26rpx;
  font-weight: 600;
}

.student-meta {
  font-size: 24rpx;
  color: #6b7280;
}

.info-row {
  display: flex;
  justify-content: space-between;
}

.label {
  font-size: 24rpx;
  color: #6b7280;
}

.value {
  font-size: 24rpx;
  color: #1f2d3d;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 100rpx;
  padding: 0 24rpx;
  background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.total {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.total-label {
  font-size: 24rpx;
  color: #6b7280;
}

.total-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff4d6a;
}

.action-btn {
  min-width: 220rpx;
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: 12rpx;
  background: #1a5fdb;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

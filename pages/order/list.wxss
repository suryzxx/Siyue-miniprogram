/* 页面基础样式 */
page {
  width: 100%;
  min-height: 100vh;
  background-color: #f6f6f8;
  color: #1f2d3d;
}

.page {
  width: 100%;
  min-height: 100vh;
  background-color: #f6f6f8;
}

.page-container {
  width: 100%;
  min-height: 100vh;
}

/* Tab栏 */
.tabs {
  display: flex;
  background: #ffffff;
  border-bottom: 1rpx solid #f1f5f9;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 32rpx 0;
  border-bottom: 4rpx solid transparent;
}

.tab text {
  font-size: 28rpx;
  color: #64748b;
}

.tab.is-active {
  border-bottom-color: #9e8ef1;
}

.tab.is-active text {
  color: #9e8ef1;
  font-weight: 500;
}

/* 滚动区域 */
.scrollarea {
  width: 100%;
  min-height: 100vh;
}

.content {
  padding: 32rpx;
  padding-bottom: 120rpx;
}

/* 订单卡片 */
.order-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(31, 45, 61, 0.04);
  border: 1rpx solid rgba(158, 142, 241, 0.2);
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
}

.order-card:active {
  opacity: 0.9;
}

/* 锁定标识 */
.locked-badge {
  position: absolute;
  top: 32rpx;
  right: -48rpx;
  background: #f59e0b;
  color: #ffffff;
  font-size: 20rpx;
  padding: 8rpx 56rpx;
  transform: rotate(45deg);
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.header-left {
  flex: 1;
}

.class-name {
  font-size: 36rpx;
  font-weight: 500;
  color: #1f2d3d;
  display: block;
  margin-bottom: 8rpx;
}

.tag-group {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.tag {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
}

.tag-system {
  background: rgba(158, 142, 241, 0.1);
  color: #9e8ef1;
}

.tag-special {
  background: rgba(158, 142, 241, 0.1);
  color: #9e8ef1;
}

.tag-level {
  background: rgba(158, 142, 241, 0.1);
  color: #9e8ef1;
}

.status-label {
  font-size: 24rpx;
  font-weight: 500;
  flex-shrink: 0;
}

/* 卡片内容 */
.card-body {
  padding: 16rpx 0;
  border-top: 1rpx solid #f6f6f8;
  border-bottom: 1rpx solid #f6f6f8;
}

.info-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  width: 80rpx;
  font-size: 24rpx;
  color: #64748b;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 24rpx;
  color: #1f2d3d;
}

.info-value.schedule {
  font-size: 22rpx;
  color: #64748b;
}

/* 退费信息 */
.refund-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f6f6f8;
  background: rgba(158, 142, 241, 0.04);
  margin: 0 -32rpx;
  padding: 12rpx 32rpx;
}

.refund-label {
  font-size: 24rpx;
  color: #9e8ef1;
}

.refund-amount {
  font-size: 28rpx;
  font-weight: 600;
  color: #9e8ef1;
}

/* 卡片底部 */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
}

.price-wrap {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.price-label {
  font-size: 24rpx;
  color: #64748b;
}

.price-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #ef4444;
}

.action-wrap {
  display: flex;
  gap: 16rpx;
}

.pay-btn {
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #9e8ef1 0%, #7e6ef1 100%);
  border-radius: 48rpx;
  box-shadow: 0 4rpx 16rpx rgba(158, 142, 241, 0.3);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 500;
}

.detail-btn {
  padding: 16rpx 32rpx;
  background: rgba(158, 142, 241, 0.1);
  border-radius: 48rpx;
}

.detail-btn text {
  color: #9e8ef1;
  font-size: 26rpx;
  font-weight: 500;
}

/* 按下效果 */
.is-pressed {
  opacity: 0.85;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 28rpx;
  color: #64748b;
}

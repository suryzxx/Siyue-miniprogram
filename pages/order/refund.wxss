page {
  height: 100vh;
  background: #f5f6f8;
  color: #1f2d3d;
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.page-container {
  flex: 1;
}

.content {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(31, 45, 61, 0.08);
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.label {
  font-size: 24rpx;
  color: #6b7280;
}

.value {
  font-size: 24rpx;
  color: #1f2d3d;
}

.value.highlight {
  color: #ff4d6a;
  font-weight: 600;
}

.textarea {
  min-height: 160rpx;
  border-radius: 12rpx;
  background: #f6f7fb;
  padding: 16rpx;
  font-size: 26rpx;
}

.primary-btn {
  height: 72rpx;
  border-radius: 12rpx;
  background: #1a5fdb;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

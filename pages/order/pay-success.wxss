page {
  height: 100vh;
  background: #f6f6f8;
  color: #1f2d3d;
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.page-container {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.content {
  padding: 60rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.success-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(31, 45, 61, 0.08);
  width: 100%;
  box-sizing: border-box;
}

.success-image {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
}

.success-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #10b981;
  margin-bottom: 16rpx;
}

.success-desc {
  font-size: 28rpx;
  color: #666666;
  text-align: center;
  line-height: 1.5;
}

.action-row {
  display: flex;
  gap: 24rpx;
  margin-top: 48rpx;
  width: 100%;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.action-btn.primary {
  background: #9e8ef1;
  color: #ffffff;
}

.action-btn.ghost {
  background: #ffffff;
  color: #9e8ef1;
  border: 2rpx solid #9e8ef1;
}

.link-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 32rpx;
  padding: 16rpx;
}

.link-text {
  font-size: 28rpx;
  color: #9e8ef1;
}

.link-arrow {
  font-size: 32rpx;
  color: #9e8ef1;
}

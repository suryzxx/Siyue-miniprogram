page {
  height: 100vh;
  background: linear-gradient(180deg, #f8f4ff 0%, #f5f6f8 200rpx);
  color: #1f2d3d;
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.page-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding-bottom: 160rpx;
}

.scrollarea {
  flex: 1;
}

.content {
  padding: 24rpx 24rpx 40rpx;
}

/* 加载中 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
  color: #999999;
  font-size: 28rpx;
}

/* 状态卡片 */
.status-card {
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #9e8ef1 0%, #b8a9f5 100%);
  display: flex;
  align-items: center;
  position: relative;
}

.status-info {
  flex: 1;
}

.status-label {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.status-tip {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.5;
}

.locked-tag {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 6rpx 16rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #ffffff;
}

/* 卡片通用样式 */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(158, 142, 241, 0.08);
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2d3d;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

/* 班级信息 */
.class-header {
  margin-bottom: 16rpx;
}

.class-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2d3d;
  display: block;
  margin-bottom: 12rpx;
}

.tag-group {
  display: flex;
  gap: 8rpx;
}

.tag {
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
}

.tag-type {
  background: rgba(158, 142, 241, 0.1);
  color: #9e8ef1;
}

.tag-level {
  background: rgba(158, 142, 241, 0.1);
  color: #9e8ef1;
}


/* 信息列表 */
.info-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.info-label {
  font-size: 26rpx;
  color: #888888;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: #333333;
  text-align: right;
  flex: 1;
  margin-left: 24rpx;
  word-break: break-all;
}

.info-value.price {
  color: #ef4444;
  font-weight: 600;
  font-size: 28rpx;
}

.info-value.highlight {
  color: #9e8ef1;
  font-weight: 600;
}

.info-value.warning {
  color: #ff8c00;
  font-weight: 600;
}

.info-value.copy {
  color: #9e8ef1;
  text-decoration: underline;
}

/* 退费信息卡片 */
.refund-card {
  background: linear-gradient(135deg, #fff5f5 0%, #ffffff 100%);
  border: 1rpx solid rgba(239, 68, 68, 0.1);
}

.info-value.refund {
  color: #ef4444;
  font-weight: 600;
}

/* 底部占位 */
.bottom-placeholder {
  height: 140rpx;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.pay-btn-full {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #9e8ef1;
  border-radius: 44rpx;
}

.pay-btn-full text {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
}

.locked-tip {
  font-size: 24rpx;
  color: #ff8c00;
  padding: 16rpx 24rpx;
  background: rgba(255, 140, 0, 0.1);
  border-radius: 12rpx;
}

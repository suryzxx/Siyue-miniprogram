page {
  height: 100vh;
  background: #f5f6f8;
  color: #1f2d3d;
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.page-container {
  flex: 1;
}

.scrollarea {
  height: 100%;
}

.content {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(31, 45, 61, 0.08);
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.course-title {
  font-size: 28rpx;
  font-weight: 600;
}

.course-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.status-chip {
  margin-top: 12rpx;
  display: inline-block;
  padding: 6rpx 14rpx;
  border-radius: 10rpx;
  background: #fff3e0;
  color: #ff8c00;
  font-size: 22rpx;
}

.queue {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.stepper {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx 24rpx;
}

.step {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 6rpx;
  background: #d5d9df;
}

.dot.active {
  background: #1a5fdb;
}

.step-text {
  font-size: 24rpx;
  color: #4f5b66;
}

.plain-text {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 36rpx;
}

.action-row {
  display: flex;
  gap: 16rpx;
}

.primary-btn {
  flex: 1;
  height: 72rpx;
  border-radius: 12rpx;
  background: #1a5fdb;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

.ghost-btn {
  flex: 1;
  height: 72rpx;
  border-radius: 12rpx;
  background: #e8edf8;
  color: #1a5fdb;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

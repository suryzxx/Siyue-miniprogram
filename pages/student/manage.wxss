/* 页面基础样式 */
page {
  height: 100vh;
  background: #f6f6f8;
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f6f6f8;
}

.page-container {
  flex: 1;
  overflow: hidden;
  position: relative;
}

.scrollarea {
  height: 100%;
}

.content {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 48rpx;
  padding-bottom: 200rpx;
}

/* 当前学生区块 */
.current-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.section-header {
  padding: 0 8rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1f2937;
}

/* 当前学生卡片 */
.current-card {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid rgba(158, 142, 241, 0.1);
  transition: all 0.3s ease;
}

.current-card:active {
  transform: scale(0.99);
  box-shadow: 0 4rpx 16rpx rgba(158, 142, 241, 0.15);
}

.card-content {
  padding: 32rpx;
  display: flex;
  gap: 32rpx;
}

.card-left {
  flex-shrink: 0;
}

.student-avatar {
  width: 192rpx;
  height: 192rpx;
  border-radius: 96rpx;
  background-size: cover;
  background-position: center;
}

.card-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 12rpx;
}

.student-header {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.student-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #1f2937;
}

.english-name {
  font-size: 28rpx;
  color: #9ca3af;
}

.student-meta {
  font-size: 26rpx;
  color: #9ca3af;
}

.student-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 8rpx;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.info-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.5;
}

.info-text {
  font-size: 24rpx;
  color: #6b7280;
}

.student-id {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 8rpx;
}

.id-text {
  font-size: 24rpx;
  color: #9ca3af;
}

.card-footer {
  padding: 24rpx 32rpx;
  border-top: 1rpx solid rgba(158, 142, 241, 0.1);
}

.edit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #b0a2f4 0%, #8c7ae9 100%);
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(158, 142, 241, 0.3);
  transition: all 0.2s ease;
}

.edit-btn:active {
  transform: scale(0.96);
}

.btn-icon {
  width: 32rpx;
  height: 32rpx;
  filter: brightness(0) invert(1);
}

.btn-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.empty-icon-wrapper {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 32rpx;
  opacity: 0.3;
}

.empty-icon {
  width: 100%;
  height: 100%;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #9ca3af;
  text-align: center;
}

/* 学生列表区块 */
.list-section {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.list-header {
  display: flex;
  align-items: center;
  padding: 0 8rpx 24rpx;
  gap: 16rpx;
}

.list-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1f2937;
}

.quota-wrapper {
  flex-shrink: 0;
}

.quota-text {
  font-size: 28rpx;
  color: #6b7280;
}

.progress-bar {
  flex: 1;
  height: 8rpx;
  background: #e5e7eb;
  border-radius: 4rpx;
  overflow: hidden;
  margin-left: 16rpx;
}

.progress-fill {
  height: 100%;
  background: #9e8ef1;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.student-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-bottom: 40rpx;
}

/* 学生列表项 */
.student-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.student-item.is-current {
  border-left: 8rpx solid #9e8ef1;
  background: linear-gradient(135deg, #fafafa 0%, #f9f7ff 100%);
}

.item-left {
  flex-shrink: 0;
}

.item-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: rgba(158, 142, 241, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 1);
  background-size: cover;
  background-position: center;
}

.item-center {
  flex: 1;
  min-width: 0;
}

.item-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.item-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
}

.current-badge {
  padding: 4rpx 12rpx;
  background: #9e8ef1;
  border-radius: 4rpx;
}

.badge-text {
  font-size: 20rpx;
  font-weight: 600;
  color: #ffffff;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.item-meta-row {
  margin-top: 8rpx;
}

.item-meta {
  font-size: 26rpx;
  color: #9ca3af;
}

.item-right {
  display: flex;
  gap: 16rpx;
  flex-shrink: 0;
}

/* 操作按钮 */
.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.95);
}

.switch-btn {
  padding: 16rpx 24rpx;
  border: 2rpx solid #9e8ef1;
  border-radius: 12rpx;
  background: transparent;
}

.switch-btn .action-text {
  font-size: 24rpx;
  color: #9e8ef1;
}

.icon-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
  background: rgba(158, 142, 241, 0.1);
}

.icon-btn .action-icon {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.8;
}

.delete-btn {
  background: rgba(239, 68, 68, 0.1);
}

.delete-btn .action-icon {
  opacity: 1;
}

/* 底部固定按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  background: linear-gradient(to top, #f6f6f8 0%, rgba(246, 246, 248, 0.95) 50%, transparent 100%);
}

.add-button {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  height: 112rpx;
  background: linear-gradient(135deg, #b0a2f4 0%, #8c7ae9 100%);
  border-radius: 16rpx;
  box-shadow: 0 12rpx 32rpx rgba(158, 142, 241, 0.4);
  transition: all 0.2s ease;
}

.add-button:active {
  transform: scale(0.98);
}

.add-button.disabled {
  opacity: 0.5;
  box-shadow: none;
}

.add-icon {
  width: 40rpx;
  height: 40rpx;
  filter: brightness(0) invert(1);
}

.add-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

/* 底部安全区域 */
.safe-area-bottom {
  height: 40rpx;
}

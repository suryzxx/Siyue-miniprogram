/* 页面基础样式 */
page {
  height: 100vh;
  background: #f6f6f8;
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f6f6f8;
}

.page-container {
  flex: 1;
  overflow: hidden;
  position: relative;
}

.scrollarea {
  height: 100%;
}

.content {
  padding: 32rpx;
  padding-bottom: 200rpx;
  max-width: 750rpx;
  margin: 0 auto;
}

/* 表单区块 */
.form-section {
  margin-bottom: 32rpx;
}

.section-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #6b7280;
  padding: 0 8rpx 24rpx;
}

.cell-note-right {
  text-align: right !important;
  color: #1f2937 !important;
}

.t-input {
  --td-input-text-color: #1f2937;
  --td-input-placeholder-color: #9ca3af;
}

.t-input__control {
  text-align: right !important;
}

.picker-placeholder {
  color: #9ca3af !important;
}

.picker-value {
  color: #1f2937 !important;
}

/* 底部固定按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  background: rgba(246, 246, 248, 0.95);
  backdrop-filter: blur(20rpx);
  border-top: 2rpx solid rgba(158, 142, 241, 0.1);
  z-index: 999;
}

.bottom-bar .t-button {
  --td-button-primary-bg-color: #9e8ef1;
  --td-button-primary-border-color: #9e8ef1;
  --td-button-primary-text-color: #ffffff;
  --td-button-border-radius: 16rpx;
  --td-button-height: 112rpx;
  --td-button-font-size: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(158, 142, 241, 0.3);
}

/* 底部安全区域 */
.safe-area-bottom {
  height: 40rpx;
}

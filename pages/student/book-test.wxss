/* 页面基础样式 */
page {
  width: 100%;
  min-height: 100vh;
  background-color: #f6f6f8;
  color: #1f2d3d;
}

.page {
  width: 100%;
  min-height: 100vh;
  background-color: #f6f6f8;
}

.page-container {
  width: 100%;
  min-height: 100vh;
}

.scrollarea {
  width: 100%;
  min-height: 100vh;
}

.content {
  padding: 32rpx;
  padding-bottom: 120rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 卡片 */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(31, 45, 61, 0.04);
  border: 1rpx solid rgba(158, 142, 241, 0.2);
}

.section-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #1f2d3d;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f6f6f8;
}

/* 学生信息 */
.student-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #f6f6f8;
}

.student-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.student-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1f2d3d;
}

.student-meta {
  font-size: 24rpx;
  color: #64748b;
}

/* 表单字段 */
.field {
  margin-bottom: 24rpx;
}

.field:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 12rpx;
}

.picker-box {
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  background: #f6f6f8;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: #1f2d3d;
}

.picker-box.is-disabled {
  opacity: 0.5;
}

.picker-box .placeholder {
  color: #94a3b8;
}

.picker-arrow {
  width: 24rpx;
  height: 24rpx;
}

/* 校区地址 */
.campus-address {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin-top: 16rpx;
  padding: 16rpx;
  background: #f6f6f8;
  border-radius: 12rpx;
}

.address-icon {
  width: 28rpx;
  height: 28rpx;
}

.address-text {
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.5;
}

/* 按钮 */
.primary-btn {
  height: 96rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #9e8ef1 0%, #7e6ef1 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(158, 142, 241, 0.3);
}

.primary-btn text {
  font-size: 30rpx;
  font-weight: 500;
  color: #ffffff;
}

.primary-btn.is-disabled {
  background: #cbd5e1;
  box-shadow: none;
}

.secondary-btn {
  height: 96rpx;
  border-radius: 48rpx;
  background: rgba(158, 142, 241, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.secondary-btn text {
  font-size: 30rpx;
  font-weight: 500;
  color: #9e8ef1;
}

/* 成功卡片 */
.success-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
}

.success-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #9e8ef1 0%, #7e6ef1 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.success-icon text {
  font-size: 48rpx;
  color: #ffffff;
}

.success-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #1f2d3d;
  margin-bottom: 8rpx;
}

.success-desc {
  font-size: 26rpx;
  color: #64748b;
}

/* 信息行 */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f6f6f8;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #64748b;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: #1f2d3d;
  text-align: right;
  flex: 1;
  margin-left: 24rpx;
}

/* 联系方式 */
.contact-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background: #f6f6f8;
  border-radius: 16rpx;
}

.contact-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.contact-label {
  font-size: 22rpx;
  color: #64748b;
}

.contact-phone {
  font-size: 30rpx;
  font-weight: 500;
  color: #1f2d3d;
}

.contact-actions {
  display: flex;
  gap: 16rpx;
}

.contact-btn {
  padding: 12rpx 24rpx;
  border-radius: 16rpx;
  background: rgba(158, 142, 241, 0.1);
}

.contact-btn text {
  font-size: 24rpx;
  font-weight: 500;
  color: #9e8ef1;
}

.contact-btn.is-primary {
  background: linear-gradient(135deg, #9e8ef1 0%, #7e6ef1 100%);
}

.contact-btn.is-primary text {
  color: #ffffff;
}

/* 按钮组 */
.btn-group {
  display: flex;
  gap: 20rpx;
}

.btn-group .secondary-btn,
.btn-group .primary-btn {
  flex: 1;
}

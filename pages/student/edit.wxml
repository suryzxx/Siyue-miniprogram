<view class="page">
  <custom-navbar
    center-text="编辑学生"
    show-left="{{true}}"
    show-right="{{false}}"
    show-back="{{true}}"
    left-icon="/images/icons/back.svg"
  />

  <view class="page-container" style="padding-top: {{navBarHeight}}px;">
    <scroll-view class="scrollarea" scroll-y enhanced show-scrollbar="{{false}}">
      <view class="content">
        <!-- 基本信息 -->
        <view class="form-section">
          <view class="section-label">基本信息</view>
          <t-cell-group>
            <!-- 姓名 -->
            <t-input
              label="学生姓名"
              placeholder="请输入学生姓名"
              value="{{student.name}}"
              bind:change="onNameInput"
              borderless="{{false}}"
              layout="horizontal"
              align-items="right"
            />

            <!-- 年级 -->
            <t-cell
              title="在读年级"
              note="{{gradeIndex >= 0 ? grades[gradeIndex].name : ''}}"
              arrow
              hover
              bind:click="onGradeCellTap"
              t-class-note="cell-note-right"
            />

            <!-- 性别 -->
            <t-cell
              title="性别"
              note="{{student.sex === 1 ? '男' : student.sex === 2 ? '女' : ''}}"
              arrow
              hover
              bind:click="onGenderCellTap"
              t-class-note="cell-note-right"
            />

            <!-- 生日 -->
            <t-cell
              title="出生日期"
              note="{{student.birthday || ''}}"
              arrow
              hover
              bind:click="onBirthdayCellTap"
              t-class-note="cell-note-right"
            />
          </t-cell-group>
        </view>

        <!-- 其他信息 -->
        <view class="form-section">
          <view class="section-label">其他信息</view>
          <t-cell-group>
            <!-- 英文名 -->
            <t-input
              label="英文名"
              placeholder="请输入英文名"
              value="{{student.en_name}}"
              bind:change="onEnglishNameInput"
              borderless="{{false}}"
              layout="horizontal"
              align-items="right"
            />

            <!-- 学校 -->
            <t-input
              label="在读学校"
              placeholder="请输入在读学校"
              value="{{student.school}}"
              bind:change="onSchoolInput"
              borderless="{{false}}"
              layout="horizontal"
              align-items="right"
            />

            <!-- 校区 -->
            <t-cell
              title="选择校区"
              note="{{campusIndex >= 0 ? campuses[campusIndex].name : ''}}"
              arrow
              hover
              bind:click="onCampusCellTap"
              t-class-note="cell-note-right"
            />
          </t-cell-group>
        </view>

        <!-- 底部安全区域 -->
        <view class="safe-area-bottom"></view>
      </view>
    </scroll-view>

    <!-- 底部固定按钮 -->
    <view class="bottom-bar">
      <t-button
        theme="primary"
        size="large"
        block
        loading="{{loading}}"
        disabled="{{loading}}"
        bind:tap="onSubmit"
      >
        {{loading ? '保存中...' : '保存修改'}}
      </t-button>
    </view>
  </view>

  <!-- 年级选择器 -->
  <t-picker
    visible="{{gradePickerVisible}}"
    value="{{gradePickerValue}}"
    data-key="grade"
    title="选择年级"
    confirm-btn="确认"
    cancel-btn="取消"
    bind:confirm="onPickerConfirm"
    bind:cancel="onPickerCancel"
  >
    <t-picker-item options="{{gradePickerOptions}}" />
  </t-picker>

  <!-- 性别选择器 -->
  <t-picker
    visible="{{genderPickerVisible}}"
    value="{{genderPickerValue}}"
    data-key="gender"
    title="选择性别"
    confirm-btn="确认"
    cancel-btn="取消"
    bind:confirm="onPickerConfirm"
    bind:cancel="onPickerCancel"
  >
    <t-picker-item options="{{genderPickerOptions}}" />
  </t-picker>

  <!-- 校区选择器 -->
  <t-picker
    visible="{{campusPickerVisible}}"
    value="{{campusPickerValue}}"
    data-key="campus"
    title="选择校区"
    confirm-btn="确认"
    cancel-btn="取消"
    bind:confirm="onPickerConfirm"
    bind:cancel="onPickerCancel"
  >
    <t-picker-item options="{{campusPickerOptions}}" />
  </t-picker>

  <!-- 生日选择器 -->
  <t-date-time-picker
    visible="{{birthdayPickerVisible}}"
    value="{{student.birthday}}"
    mode="date"
    title="选择出生日期"
    start="2010-01-01"
    end="2026-12-31"
    format="YYYY-MM-DD"
    bind:confirm="onBirthdayConfirm"
    bind:cancel="onBirthdayCancel"
  />
</view>

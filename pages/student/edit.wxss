/* 页面基础样式 */
page {
  height: 100vh;
  background: #f6f6f8;
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f6f6f8;
}

.page-container {
  flex: 1;
  overflow: hidden;
  position: relative;
}

.scrollarea {
  height: 100%;
}

.content {
  padding: 32rpx;
  padding-bottom: 200rpx;
  max-width: 750rpx;
  margin: 0 auto;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  justify-content: center;
  padding: 64rpx 0;
}

.avatar-wrapper {
  position: relative;
  width: 192rpx;
  height: 192rpx;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: rgba(158, 142, 241, 0.2);
  border: 4rpx solid rgba(158, 142, 241, 0.3);
}

.avatar-camera {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 56rpx;
  height: 56rpx;
  background: #9e8ef1;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(158, 142, 241, 0.4);
  border: 4rpx solid #f6f6f8;
}

.camera-icon {
  width: 28rpx;
  height: 28rpx;
  filter: brightness(0) invert(1);
}

/* 表单区块 */
.form-section {
  margin-bottom: 48rpx;
}

.section-label {
  font-size: 26rpx;
  font-weight: 400;
  color: #6b7280;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  padding: 0 8rpx 24rpx;
}

.form-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid rgba(158, 142, 241, 0.05);
}

/* 表单字段 */
.form-field {
  margin-bottom: 40rpx;
}

.form-field:last-child {
  margin-bottom: 0;
}

.field-label {
  display: block;
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 16rpx;
}

.field-input {
  height: 96rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  background: #f6f6f8;
  font-size: 28rpx;
  color: #1f2937;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.field-input:focus {
  border-color: rgba(158, 142, 241, 0.3);
  background: #ffffff;
}

.field-input::placeholder {
  color: #9ca3af;
}

/* 选择器样式 */
.field-picker {
  height: 96rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  background: #f6f6f8;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-value {
  font-size: 28rpx;
  color: #1f2937;
}

.picker-placeholder {
  font-size: 28rpx;
  color: #9ca3af;
}

.picker-arrow {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.4;
}

/* 性别选择 */
.gender-group {
  display: flex;
  gap: 24rpx;
}

.gender-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: #f6f6f8;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.gender-btn.is-active {
  background: #9e8ef1;
  border-color: #9e8ef1;
}

.gender-text {
  font-size: 28rpx;
  color: #6b7280;
}

.gender-btn.is-active .gender-text {
  color: #ffffff;
  font-weight: 500;
}

/* 评测等级显示 */
.level-display {
  height: 96rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  background: rgba(249, 250, 251, 1);
  border: 2rpx solid rgba(243, 244, 246, 1);
  display: flex;
  align-items: center;
}

.level-text {
  font-size: 28rpx;
  color: #6b7280;
}

/* 底部固定按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  background: rgba(246, 246, 248, 0.8);
  backdrop-filter: blur(20rpx);
  border-top: 2rpx solid rgba(158, 142, 241, 0.1);
}

.save-btn {
  height: 112rpx;
  max-width: 750rpx;
  margin: 0 auto;
  background: #9e8ef1;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(158, 142, 241, 0.3);
  transition: all 0.2s ease;
}

.save-btn:active {
  transform: scale(0.98);
}

.save-btn.is-loading {
  opacity: 0.7;
  pointer-events: none;
}

.save-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #ffffff;
}

/* 底部安全区域 */
.safe-area-bottom {
  height: 40rpx;
}

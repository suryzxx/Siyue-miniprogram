/* 首页样式 */
page {
  height: 100vh;
  background: linear-gradient(180deg, #f8f4ff 0%, #faf8fc 30%, #f7f8fa 100%);
  color: #1f2d3d;
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.page-container {
  flex: 1;
}

.scrollarea {
  height: 100%;
}

.content {
  padding: 24rpx 24rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.card {
  padding: 24rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(31, 45, 61, 0.1);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2d3d;
  margin-bottom: 20rpx;
}

/* 快捷入口 */
.quick-actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 24rpx;
  background: linear-gradient(135deg, #a78bfa 0%, #8b5cf6 100%);
  border-radius: 20rpx;
  box-shadow: 0 12rpx 32rpx rgba(139, 92, 246, 0.35);
}

.action-icon {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 12rpx;
  filter: brightness(0) invert(1);
}

.action-text {
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 600;
}

/* 名师风采 */
.teacher-swiper {
  height: 200rpx;
}

.teacher-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.teacher-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: linear-gradient(135deg, #e0e7ff 0%, #c4b5fd 100%);
  border: 3rpx solid rgba(139, 92, 246, 0.2);
}

.teacher-info {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.teacher-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.teacher-name {
  font-size: 32rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #8b5cf6 0%, #a78bfa 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.teacher-tag {
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  color: #d97706;
  font-size: 22rpx;
  font-weight: 500;
}

.teacher-desc {
  font-size: 24rpx;
  color: #8b95a1;
}

.dots {
  margin-top: 16rpx;
  display: flex;
  justify-content: center;
  gap: 12rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 6rpx;
  background: #e5e7eb;
  transition: all 0.3s ease;
}

.dot.is-active {
  width: 24rpx;
  background: linear-gradient(135deg, #a78bfa 0%, #8b5cf6 100%);
  border-radius: 4rpx;
}

/* 校区环境 */
.campus-scroll {
  white-space: nowrap;
}

.campus-list {
  display: inline-flex;
  gap: 16rpx;
}

.campus-img {
  width: 520rpx;
  height: 280rpx;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 45, 61, 0.12);
}

/* 品牌介绍 */
.brand-text {
  font-size: 26rpx;
  line-height: 44rpx;
  color: #4f5b66;
}

.is-pressed {
  opacity: 0.7;
  transform: scale(0.98);
  transition: all 0.15s ease;
}

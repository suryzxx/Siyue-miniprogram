page {
  height: 100vh;
  background: #f5f6f8;
  color: #1f2d3d;
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.page-container {
  flex: 1;
}

.scrollarea {
  height: 100%;
}

.content {
  padding: 24rpx 24rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 10rpx 24rpx rgba(31, 45, 61, 0.08);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.field {
  margin-bottom: 16rpx;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 8rpx;
}

.input {
  height: 72rpx;
  padding: 0 20rpx;
  border-radius: 12rpx;
  background: #f6f7fb;
  font-size: 26rpx;
}

.code-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.code-input {
  flex: 1;
}

.code-btn {
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  background: #1a5fdb;
  color: #ffffff;
  font-size: 24rpx;
}

.chip-group {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #f1f2f6;
  color: #4f5b66;
  font-size: 24rpx;
}

.chip.is-active {
  background: #1a5fdb;
  color: #ffffff;
}

.hint {
  font-size: 26rpx;
  color: #6b7280;
}

.hint-text {
  margin-bottom: 16rpx;
  font-size: 24rpx;
  color: #9ca3af;
  text-align: center;
}

.date-row {
  display: flex;
  gap: 16rpx;
}

.date-picker {
  flex: 1;
  height: 72rpx;
  padding: 0 20rpx;
  border-radius: 12rpx;
  background: #f6f7fb;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 26rpx;
}

.date-picker .arrow {
  font-size: 20rpx;
  color: #9ca3af;
}

.code-btn.disabled {
  background: #9ca3af;
}

.primary-btn {
  height: 72rpx;
  border-radius: 12rpx;
  background: #1a5fdb;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

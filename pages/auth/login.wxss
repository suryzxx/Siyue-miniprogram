/* 页面样式 - 登录页 */
page {
  height: 100vh;
  background: #f6f6f8;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.page {
  position: relative;
  min-height: 100vh;
  width: 100%;
  display: flex;
  flex-direction: column;
  overflow-x: hidden;
}



/* 装饰背景 */
.bg-decor-top {
  position: fixed;
  top: -192rpx;
  right: -192rpx;
  width: 512rpx;
  height: 512rpx;
  background: rgba(158, 142, 241, 0.1);
  border-radius: 50%;
  filter: blur(96rpx);
  pointer-events: none;
}

.bg-decor-bottom {
  position: fixed;
  bottom: -192rpx;
  left: -192rpx;
  width: 512rpx;
  height: 512rpx;
  background: rgba(158, 142, 241, 0.1);
  border-radius: 50%;
  filter: blur(96rpx);
  pointer-events: none;
}

/* 主内容区域 */
.main-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 0 48rpx;
  padding-bottom: 64rpx;
}

/* 品牌区域 */
.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 128rpx;
}

.brand-logo {
  width: 256rpx;
  height: 256rpx;
  background: rgba(158, 142, 241, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(158, 142, 241, 0.2);
  border: 8rpx solid #ffffff;
  overflow: hidden;
}

.logo-icon {
  width: 128rpx;
  height: 128rpx;
}

.brand-name {
  margin-top: 48rpx;
  font-size: 48rpx;
  font-weight: 700;
  color: #1f2937;
  letter-spacing: -0.02em;
}

.brand-slogan {
  margin-top: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #9e8ef1;
}

/* 登录按钮区域 */
.login-actions {
  margin-top: 192rpx;
  width: 100%;
}

.primary-btn {
  width: 100%;
  height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 9999rpx;
  background: linear-gradient(135deg, #b3a7f4 0%, #8a76ed 100%);
  box-shadow: 0 16rpx 48rpx rgba(138, 118, 237, 0.3);
  border: none;
  transition: all 0.2s ease;
}

.primary-btn:active {
  transform: scale(0.98);
}

.btn-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 0.02em;
}

/* 协议区域 */
.agreement-section {
  margin-top: 32rpx;
  width: 100%;
}

.agreement-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.checkbox {
  flex-shrink: 0;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 4rpx solid #d1d5db;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.checkbox.is-checked {
  background: #9e8ef1;
  border-color: #9e8ef1;
}

.checkbox-icon {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 700;
}

.agreement-text {
  flex: 1;
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  align-items: center;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6b7280;
}

.agreement-text text {
  flex-shrink: 0;
}

.agreement-link {
  color: #9e8ef1;
  font-weight: 500;
}

/* 登录表单区域 */
.login-form {
  margin-top: 96rpx;
  width: 100%;
}

.form-item {
  margin-bottom: 32rpx;
}

.input-wrapper {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #ffffff;
  border-radius: 9999rpx;
  padding: 0 32rpx;
  height: 112rpx;
  border: 2rpx solid rgba(158, 142, 241, 0.2);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.input-prefix {
  font-size: 32rpx;
  font-weight: 500;
  color: #1f2937;
  margin-right: 16rpx;
  padding-right: 16rpx;
  border-right: 2rpx solid #e5e7eb;
}

.input-field {
  flex: 1;
  font-size: 32rpx;
  color: #1f2937;
  height: 100%;
}

.input-field::placeholder {
  color: #9ca3af;
}

/* 验证码输入 */
.code-wrapper {
  padding-right: 16rpx;
}

.code-input {
  flex: 1;
}

.code-btn {
  flex-shrink: 0;
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #b3a7f4 0%, #8a76ed 100%);
  border-radius: 9999rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
}

.code-btn.disabled {
  background: #e5e7eb;
  color: #9ca3af;
}

/* 登录按钮 */
.login-btn {
  width: 100% !important;
  height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 9999rpx;
  background: linear-gradient(135deg, #b3a7f4 0%, #8a76ed 100%);
  box-shadow: 0 16rpx 48rpx rgba(138, 118, 237, 0.3);
  border: none;
  margin-top: 48rpx;
}

.login-btn:active {
  transform: scale(0.98);
}

.login-btn.loading {
  opacity: 0.7;
}

.login-btn-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 0.02em;
}

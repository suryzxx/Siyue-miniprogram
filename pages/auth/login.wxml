<view class="page">
<custom-navbar
    center-text="登录"
    show-left="{{true}}"
    show-right="{{false}}"
    show-back="{{false}}"
    left-icon="/images/icons/close.svg"
    bind:lefttap="onCloseTap"
  />

  <!-- 装饰背景 -->
  <view class="bg-decor-top"></view>
  <view class="bg-decor-bottom"></view>

  <!-- 主内容区域 -->
  <view class="main-content" style="padding-top: {{navBarHeight}}px;">
    <!-- 品牌区域 -->
    <view class="brand-section">
      <text class="brand-name">思悦云学习</text>
    </view>

    <!-- 登录区域 -->
    <view class="login-form">
      <!-- 微信手机号授权登录按钮 -->
      <button 
        class="login-btn {{loading ? 'loading' : ''}}" 
        open-type="getPhoneNumber"
        bindgetphonenumber="onGetPhoneNumber"
        disabled="{{!agreed}}"
      >
        <text class="login-btn-text">{{loading ? '登录中...' : '微信手机号快速登录'}}</text>
      </button>

      <!-- 协议区域 -->
      <view class="agreement-section">
        <view class="agreement-row" bindtap="onAgreementToggle">
          <view class="checkbox {{agreed ? 'is-checked' : ''}}">
            <text class="checkbox-icon" wx:if="{{agreed}}">✓</text>
          </view>
          <view class="agreement-text">
            <text>我已阅读并同意</text>
            <text class="agreement-link" bindtap="onUserAgreementTap" catchtap="onUserAgreementTap">《用户协议》</text>
            <text>和</text>
            <text class="agreement-link" bindtap="onPrivacyAgreementTap" catchtap="onPrivacyAgreementTap">《隐私协议》</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>

<view class="page">
<custom-navbar
    center-text="登录"
    show-left="{{true}}"
    show-right="{{false}}"
    show-back="{{false}}"
    left-icon="/images/icons/close.svg"
    bind:lefttap="onCloseTap"
  />

  <!-- 装饰背景 -->
  <view class="bg-decor-top"></view>
  <view class="bg-decor-bottom"></view>

  <!-- 主内容区域 -->
  <view class="main-content" style="padding-top: {{navBarHeight}}px;">
    <!-- 品牌区域 -->
    <view class="brand-section">
      <view class="brand-logo">
        <image class="logo-icon" src="/images/logo.png" mode="aspectFit" />
      </view>
      <text class="brand-name">思悦云学习</text>
      <text class="brand-slogan">赋能终身学习</text>
    </view>

    <!-- 登录表单区域 -->
    <view class="login-form">
      <!-- 手机号输入 -->
      <view class="form-item">
        <view class="input-wrapper">
          <text class="input-prefix">+86</text>
          <input 
            class="input-field"
            type="number"
            maxlength="11"
            placeholder="请输入手机号"
            value="{{phone}}"
            bindinput="onPhoneInput"
          />
        </view>
      </view>

      <!-- 验证码输入 -->
      <view class="form-item">
        <view class="input-wrapper code-wrapper">
          <input 
            class="input-field code-input"
            type="number"
            maxlength="6"
            placeholder="请输入验证码"
            value="{{code}}"
            bindinput="onCodeInput"
          />
          <view 
            class="code-btn {{canSend ? '' : 'disabled'}}" 
            bindtap="onSendCode"
          >
            <text>{{sendText}}</text>
          </view>
        </view>
      </view>

      <!-- 登录按钮 -->
      <button class="login-btn {{loading ? 'loading' : ''}}" bindtap="onLogin">
        <text class="login-btn-text">{{loading ? '登录中...' : '登录'}}</text>
      </button>

      <!-- 协议区域 -->
      <view class="agreement-section">
        <view class="agreement-row" bindtap="onAgreementToggle">
          <view class="checkbox {{agreed ? 'is-checked' : ''}}">
            <text class="checkbox-icon" wx:if="{{agreed}}">✓</text>
          </view>
          <view class="agreement-text">
            <text>我已阅读并同意</text>
            <text class="agreement-link" bindtap="onUserAgreementTap" catchtap="onUserAgreementTap">《用户协议》</text>
            <text>和</text>
            <text class="agreement-link" bindtap="onPrivacyAgreementTap" catchtap="onPrivacyAgreementTap">《隐私协议》</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 测试账号提示 -->
    <view class="test-hint">
      <text class="hint-title">测试账号：</text>
      <text class="hint-text">17788889999（有学生）</text>
      <text class="hint-text">12233334444（无学生）</text>
      <text class="hint-text">验证码任意6位数字</text>
    </view>
  </view>
</view>

/* 筛选栏 */
.filter-bar {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-bottom: 1rpx solid rgba(158, 142, 241, 0.08);
  position: sticky;
  top: 0;
  z-index: 10;
  height: 88rpx;
}

.filter-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 0 16rpx;
}

.filter-item:active {
  background: #f8f7fc;
}

.filter-label {
  font-size: 28rpx;
  color: #666666;
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}

.filter-label.is-active {
  color: #9e8ef1;
  font-weight: 600;
}

.filter-icon {
  margin-left: 8rpx;
  color: #999999;
}

.filter-icon.is-active {
  color: #9e8ef1;
}

/* 弹出面板容器 */
.popup-content {
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  padding-bottom: 0 !important;
}

.popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2d3d;
}

.popup-close {
  padding: 8rpx;
}

.popup-search {
  padding: 16rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

/* 列表区域：flex: 1 确保它占据中间所有空间 */
.popup-list {
  flex: 1;
  padding: 8rpx 0;
  min-height: 0;
}

.popup-list.has-max-height {
  max-height: 480rpx;
}

.popup-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  transition: background 0.2s ease;
}

.popup-item:active {
  background: #faf8ff;
}

.popup-item-text {
  font-size: 30rpx;
  color: #333333;
}

.popup-item.is-selected .popup-item-text {
  color: #9e8ef1;
  font-weight: 600;
}

.check-icon {
  color: #9e8ef1;
}

/* 底部按钮区：核心修复位置 */
.popup-footer {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx 0rpx !important;
  border-top: 1rpx solid #f0f0f0;
  gap: 24rpx;
  flex-shrink: 0;
  background: #ffffff;
}

.reset-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 80rpx;
  padding: 0 40rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 40rpx;
  color: #666666;
  font-size: 28rpx;
  background: #ffffff;
}

.confirm-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  background: #9e8ef1;
  border-radius: 40rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
}
<!-- 筛选栏 -->
<view class="filter-bar">
  <!-- 学期筛选 -->
  <view class="filter-item" bindtap="onSemesterTap">
    <text class="filter-label {{currentFilters.semester ? 'is-active' : ''}}">{{currentFilters.semesterName || '学期'}}</text>
    <t-icon name="caret-down-small" size="32rpx" class="filter-icon {{currentFilters.semester ? 'is-active' : ''}}" />
  </view>
  
  <!-- 校区筛选 -->
  <view class="filter-item" bindtap="onCampusTap">
    <text class="filter-label {{currentFilters.campusId ? 'is-active' : ''}}">{{currentFilters.campusName || '校区'}}</text>
    <t-icon name="caret-down-small" size="32rpx" class="filter-icon {{currentFilters.campusId ? 'is-active' : ''}}" />
  </view>
  
  <!-- 老师筛选 -->
  <view class="filter-item" bindtap="onTeacherTap">
    <text class="filter-label {{currentFilters.teacherId ? 'is-active' : ''}}">{{currentFilters.teacherName || '老师'}}</text>
    <t-icon name="caret-down-small" size="32rpx" class="filter-icon {{currentFilters.teacherId ? 'is-active' : ''}}" />
  </view>
</view>

<!-- 学期选择面板 -->
<t-popup
  visible="{{showSemesterPopup}}"
  placement="bottom"
  bind:visible-change="onSemesterPopupChange"
  close-on-overlay-click="{{true}}"
  safe-area-inset-bottom="{{false}}"
>
  <view class="popup-content">
    <view class="popup-header">
      <text class="popup-title">选择学期</text>
      <view class="popup-close" bindtap="onCloseSemesterPopup">
        <t-icon name="close" size="40rpx" />
      </view>
    </view>
    <scroll-view class="popup-list" scroll-y>
      <view 
        class="popup-item {{item.selected ? 'is-selected' : ''}}"
        wx:for="{{semesterOptions}}"
        wx:key="id"
        data-item="{{item}}"
        bindtap="onSelectSemester"
      >
        <text class="popup-item-text">{{item.name}}</text>
        <t-icon wx:if="{{item.selected}}" name="check" size="36rpx" class="check-icon" />
      </view>
    </scroll-view>
    <view class="popup-footer">
      <view class="reset-btn" bindtap="onResetSemester">
        <t-icon name="refresh" size="32rpx" />
        <text>重置</text>
      </view>
      <view class="confirm-btn" bindtap="onConfirmSemester">
        <text>确定</text>
      </view>
    </view>
  </view>
</t-popup>

<!-- 校区选择面板 -->
<t-popup
  visible="{{showCampusPopup}}"
  placement="bottom"
  bind:visible-change="onCampusPopupChange"
  close-on-overlay-click="{{true}}"
  safe-area-inset-bottom="{{false}}"
>
  <view class="popup-content">
    <view class="popup-header">
      <text class="popup-title">选择校区</text>
      <view class="popup-close" bindtap="onCloseCampusPopup">
        <t-icon name="close" size="40rpx" />
      </view>
    </view>
    <view class="popup-search" wx:if="{{filters.campuses.length > 6}}">
      <t-search 
        placeholder="搜索校区" 
        value="{{campusSearchKeyword}}"
        bind:change="onCampusSearch"
        clearable
      />
    </view>
    <scroll-view class="popup-list {{campusOptions.length > 6 ? 'has-max-height' : ''}}" scroll-y>
      <view 
        class="popup-item {{item.selected ? 'is-selected' : ''}}"
        wx:for="{{campusOptions}}"
        wx:key="id"
        data-item="{{item}}"
        bindtap="onSelectCampus"
      >
        <text class="popup-item-text">{{item.name}}</text>
        <t-icon wx:if="{{item.selected}}" name="check" size="36rpx" class="check-icon" />
      </view>
      <view class="empty-tip" wx:if="{{campusOptions.length === 0 && campusSearchKeyword}}">
        <text>未找到匹配的校区</text>
      </view>
    </scroll-view>
    <view class="popup-footer">
      <view class="reset-btn" bindtap="onResetCampus">
        <t-icon name="refresh" size="32rpx" />
        <text>重置</text>
      </view>
      <view class="confirm-btn" bindtap="onConfirmCampus">
        <text>确定</text>
      </view>
    </view>
  </view>
</t-popup>

